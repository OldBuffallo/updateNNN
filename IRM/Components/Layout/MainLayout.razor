            PrimaryDarken = "#1d4ed8",
            PrimaryLighten = "#60a5fa",
            Secondary = "#6366f1",
            Tertiary = "#7c3aed",
            Info = "#2563eb",
            Success = "#059669",
            Warning = "#d97706",
