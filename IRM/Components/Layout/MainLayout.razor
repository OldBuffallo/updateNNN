            DrawerText = "rgba(255,255,255,0.7)",
            DrawerIcon = "rgba(255,255,255,0.5)",
            TextPrimary = "#1a2332",
            TextSecondary = "#5a6a7e",
            ActionDefault = "#5a6a7e",
            Divider = "#e2e8f0",
            DividerLight = "#f1f5f9",
            TableHover = "#f0f6ff",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#8ab4f8",
            PrimaryDarken = "#6d9cf7",
            PrimaryLighten = "#aecbfa",
            Secondary = "#c4b5fd",
            Tertiary = "#a78bfa",
            Info = "#8ab4f8",
            Success = "#34d399",
            Warning = "#fbbf24",
            Error = "#f87171",
            Background = "#111318",
            Surface = "#1c1f26",
            AppbarBackground = "#1c1f26",
            AppbarText = "#e4e6eb",
            DrawerBackground = "#0d1017",
