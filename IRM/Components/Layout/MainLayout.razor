@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStore

<MudThemeProvider Theme="_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* ============ LOADING SCREEN ============ *@
<div class="loading-screen" id="irmLoadingScreen">
    <div class="loading-spinner"></div>
    <div class="loading-text">Đang tải hệ thống...</div>
</div>

@* ============ LOGIN SCREEN ============ *@
@if (!_isLoggedIn)
{
    <div class="login-screen active-screen">
        <div class="login-bg">
            <div class="login-card">
                <div class="login-logo">
                    <div class="logo-icon">
                        <svg width="28" height="28" viewBox="0 0 48 48" fill="none">
                            <path d="M14 24L22 32L34 16" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <h1>Immigration Report Manager</h1>
                    <p class="login-subtitle">Hệ thống quản lý lao động nước ngoài v2.0</p>
                </div>
                <EditForm Model="_loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                    <div class="input-group">
                        <label for="loginUser">Tài khoản</label>
                        <input type="text" id="loginUser" @bind="_loginModel.Username" placeholder="Nhập tài khoản" />
                    </div>
                    <div class="input-group">
                        <label for="loginPass">Mật khẩu</label>
                        <input type="password" id="loginPass" @bind="_loginModel.Password" placeholder="Nhập mật khẩu" />
                    </div>
                    @if (!string.IsNullOrEmpty(_loginError))
                    {
                        <div style="color: #dc2626; font-size: 13px; margin-bottom: 12px; text-align: center;">@_loginError</div>
                    }
                    <button type="submit" class="btn-login">Đăng nhập</button>
                </EditForm>
                <div class="login-footer">
                    <span class="secure-badge">🔒 Kết nối bảo mật (HTTPS) · Phiên bản 2.0</span>
                </div>
            </div>
        </div>
    </div>
}

@* ============ MAIN APP ============ *@
@if (_isLoggedIn)
{
    <MudLayout Class="irm-shell">
        <MudAppBar Elevation="0" Dense="true" Class="irm-topbar">
            <div class="topbar-left">
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               Edge="Edge.Start"
                               Class="topbar-icon-btn"
                               OnClick="@ToggleDrawer" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Class="topbar-title">@_pageTitle</MudText>
                    <span class="irm-breadcrumb">
                        <a href="/">Trang chủ</a> / @_breadcrumbText
                    </span>
                </MudStack>
            </div>

            <MudSpacer />

            <div class="topbar-right">
                <MudTextField T="string"
                              @bind-Value="_topSearchQuery"
                              Placeholder="Tìm nhanh... (Ctrl+K)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Margin="Margin.Dense"
                              Class="topbar-search"
                              OnKeyUp="OnTopSearchKeyUp"
                              Immediate="true" />

                <MudBadge Dot="true" Color="Color.Error" Overlap="true">
                    <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone"
                                   Color="Color.Inherit"
                                   Class="topbar-icon-btn" />
                </MudBadge>

                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               Class="topbar-icon-btn"
                               OnClick="@ToggleDarkMode" />

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.HelpOutline"
                           Class="topbar-help-btn"
                           OnClick="@ToggleHelp">
                    Hỗ trợ
                </MudButton>
            </div>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen"
                   Elevation="2"
                   ClipMode="DrawerClipMode.Always"
                   Variant="DrawerVariant.Responsive"
                   Breakpoint="Breakpoint.Lg"
                   Class="irm-drawer">
            <MudDrawerHeader Dense="true" Class="irm-drawer-header">
                <div class="sidebar-logo-mark">
                    <MudIcon Icon="@Icons.Material.Filled.FactCheck"
                             Color="Color.Inherit"
                             Size="Size.Medium" />
                </div>

                @if (_drawerOpen)
                {
                    <MudStack Spacing="0" Class="sidebar-brand-copy">
                        <MudText Typo="Typo.subtitle1" Class="sidebar-brand-title">IRM</MudText>
                        <MudText Typo="Typo.caption" Class="sidebar-brand-badge">v2.0</MudText>
                    </MudStack>
                }
            </MudDrawerHeader>

            <NavMenu OnPageChanged="@OnPageChanged" />

            <MudSpacer />

            <div class="user-footer">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="user-footer-row">
                    <div class="user-avatar">A</div>

                    @if (_drawerOpen)
                    {
                        <MudStack Spacing="0" Class="user-footer-copy">
                            <MudText Typo="Typo.body2" Class="user-footer-name">Admin</MudText>
                            <MudText Typo="Typo.caption" Class="user-footer-role">Quản trị viên</MudText>
                        </MudStack>

                        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                                       Size="Size.Small"
                                       Class="user-footer-logout"
                                       OnClick="@Logout" />
                    }
                </MudStack>
            </div>
        </MudDrawer>

        <MudMainContent Class="irm-main">
            <MudContainer MaxWidth="MaxWidth.False" Class="irm-main-container">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>

    <MudDrawer @bind-Open="_helpOpen"
               Anchor="Anchor.End"
               Elevation="3"
               Width="380px"
               Variant="DrawerVariant.Temporary"
               Class="help-drawer">
        <MudDrawerHeader Class="help-drawer-header">
            <MudText Typo="Typo.h6" Class="help-drawer-title">Hỗ trợ sử dụng</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="@ToggleHelp"
                           Size="Size.Small"
                           Class="help-close-btn" />
        </MudDrawerHeader>

        <MudDivider />

        <MudTabs Rounded="true" Centered="true" Class="help-tabs">
            <MudTabPanel Text="Trang hiện tại" Icon="@Icons.Material.Filled.Info">
                <MudContainer Class="pa-4">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Color="Color.Primary" Class="mb-2">@_pageTitle</MudText>
                    @switch (_pageTitle)
                    {
                        case "Dashboard":
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>KPI</strong> — Hiển thị tổng số NLĐ, GPLĐ, và cảnh báo sắp hết hạn. Nhấn vào thẻ KPI để xem chi tiết.</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Biểu đồ</strong> — Phân bổ NLĐ theo quốc tịch, lĩnh vực, trạng thái GPLĐ. Di chuột để xem số liệu cụ thể.</MudAlert>
                            <MudAlert Severity="Severity.Warning" Dense="true"><strong>Cảnh báo</strong> — Danh sách NLĐ sắp hết hạn tạm trú (≤30 ngày) hiện ở bảng cảnh báo bên phải.</MudAlert>
                            break;
                        case "Quản lý Công ty":
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Thêm công ty</strong> — Nhấn nút "Thêm công ty" → điền tên, loại hình, lĩnh vực, số LĐ.</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Sửa/Xóa</strong> — Nhấn ⋮ ở cột cuối mỗi dòng → chọn Sửa hoặc Xóa.</MudAlert>
                            <MudAlert Severity="Severity.Success" Dense="true"><strong>Xuất Excel</strong> — Nhấn nút "Xuất Excel" ở thanh công cụ phía trên. File tải về dạng .xlsx.</MudAlert>
                            break;
                        case "Quản lý Nhân viên":
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Lọc</strong> — Dùng bộ lọc trên thanh công cụ: Công ty, Quốc tịch, GPLĐ, Sắp hết hạn.</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Thêm NLĐ</strong> — Nhấn "Thêm nhân viên" → điền thông tin → Lưu. Hộ chiếu sẽ được kiểm tra trùng.</MudAlert>
                            <MudAlert Severity="Severity.Warning" Dense="true"><strong>Màu sắc dòng</strong> — Đỏ: hết hạn ≤7 ngày, Cam: ≤30 ngày.</MudAlert>
                            break;
                        case "Import Excel":
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Bước 1</strong> — Upload file .xlsx hoặc .xls. Nhấn "Tải file mẫu" để lấy cấu trúc chuẩn.</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Bước 2</strong> — Ghép cột Excel với trường hệ thống. HT tự nhận dạng, bạn có thể chỉnh lại.</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Bước 3</strong> — Xem trước dữ liệu và xử lý trùng lặp (hộ chiếu). Chọn bỏ qua/cập nhật.</MudAlert>
                            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-2"><strong>Bước 4</strong> — Kết quả import với thống kê. Có thể hoàn tác (rollback) nếu cần.</MudAlert>
                            <MudAlert Severity="Severity.Warning" Dense="true"><strong>Nhập thủ công</strong> — Nhấn "✏️ Nhập thủ công" để nhập từng NLĐ mà không cần file Excel.</MudAlert>
                            break;
                        case "Tìm kiếm":
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Full-text</strong> — Tìm trên tên, hộ chiếu, visa, GPLĐ, công ty, quốc tịch, nghề nghiệp, người thân.</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Bộ lọc</strong> — Chọn chip "Nhân viên" / "Công ty" để thu hẹp kết quả.</MudAlert>
                            <MudAlert Severity="Severity.Success" Dense="true"><strong>Từ khóa được tô sáng</strong> — Từ khóa tìm kiếm sẽ được highlight trong kết quả.</MudAlert>
                            break;
                        case "Báo cáo":
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Chọn cột</strong> — Tick/untick các cột bên trái để tùy chỉnh báo cáo.</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Bộ lọc</strong> — Lọc theo GPLĐ, quốc tịch, NLĐ sắp hết hạn (30/60/90 ngày).</MudAlert>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2"><strong>Nhóm</strong> — Chọn nhóm theo Công ty, Quốc tịch, hoặc Lĩnh vực.</MudAlert>
                            <MudAlert Severity="Severity.Success" Dense="true"><strong>Xuất Excel</strong> — Nhấn "Xuất Excel" để tải file .xlsx với dữ liệu đã lọc + thống kê tóm tắt.</MudAlert>
                            break;
                        default:
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Sử dụng các chức năng trên trang để quản lý dữ liệu lao động nước ngoài.
                            </MudText>
                            break;
                    }
                    <MudAlert Severity="Severity.Normal" Dense="true" Class="mt-4">
                        <strong>Mẹo:</strong> Nhấn <strong>Ctrl+K</strong> để tìm kiếm nhanh từ bất kỳ trang nào.
                    </MudAlert>
                </MudContainer>
            </MudTabPanel>

            <MudTabPanel Text="Hướng dẫn nhanh" Icon="@Icons.Material.Filled.RocketLaunch">
                <MudContainer Class="pa-4">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-3">🚀 Bắt đầu nhanh với IRM</MudText>
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                            <MudText Typo="Typo.body2"><strong>1. Tạo công ty</strong> — Vào "Công ty" → Thêm công ty mới với thông tin cơ bản.</MudText>
                        </MudTimelineItem>
                        <MudTimelineItem Color="Color.Success" Size="Size.Small">
                            <MudText Typo="Typo.body2"><strong>2. Thêm nhân viên</strong> — Vào "Import" → Tải file mẫu → Điền dữ liệu → Upload. Hoặc nhấn "Nhập thủ công".</MudText>
                        </MudTimelineItem>
                        <MudTimelineItem Color="Color.Warning" Size="Size.Small">
                            <MudText Typo="Typo.body2"><strong>3. Theo dõi</strong> — Dashboard hiển thị KPI, biểu đồ và cảnh báo hết hạn tự động.</MudText>
                        </MudTimelineItem>
                        <MudTimelineItem Color="Color.Info" Size="Size.Small">
                            <MudText Typo="Typo.body2"><strong>4. Báo cáo</strong> — Vào "Báo cáo" → Chọn cột, bộ lọc → Xuất Excel để gửi cơ quan.</MudText>
                        </MudTimelineItem>
                    </MudTimeline>
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        ⚠️ Dữ liệu xóa sẽ được "ẩn" (soft delete), có thể phục hồi từ trang Quản trị.<br/>
                        📥 Import hỗ trợ .xlsx và .xls. Mỗi phiên import đều có lịch sử để hoàn tác.
                    </MudText>
                </MudContainer>
            </MudTabPanel>

            <MudTabPanel Text="Phím tắt" Icon="@Icons.Material.Filled.Keyboard">
                <MudSimpleTable Dense="true" Hover="true" Class="ma-4">
                    <thead>
                        <tr>
                            <th>Chức năng</th>
                            <th>Phím tắt</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Tìm kiếm nhanh</td><td><MudChip T="string" Size="Size.Small">Ctrl + K</MudChip></td></tr>
                        <tr><td>Mở hỗ trợ</td><td><MudChip T="string" Size="Size.Small">F1</MudChip></td></tr>
                        <tr><td>Về Dashboard</td><td><MudChip T="string" Size="Size.Small">Ctrl + H</MudChip></td></tr>
                        <tr><td>Thêm mới</td><td><MudChip T="string" Size="Size.Small">Ctrl + N</MudChip></td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudTabPanel>

            <MudTabPanel Text="FAQ" Icon="@Icons.Material.Filled.QuestionAnswer">
                <MudContainer Class="pa-4">
                    <MudExpansionPanels MultiExpansion="true">
                        <MudExpansionPanel Text="Tôi quên mật khẩu?" MaxHeight="200">
                            <MudText Typo="Typo.body2">Liên hệ quản trị viên để đặt lại. Vào Quản trị → Tài khoản → Đặt lại mật khẩu.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="File Excel import bị lỗi?" MaxHeight="300">
                            <MudText Typo="Typo.body2">Đảm bảo file đúng định dạng .xlsx hoặc .xls. Dòng đầu tiên phải là tiêu đề cột. Nhấn "📥 Tải file mẫu" trong trang Import để lấy cấu trúc chuẩn.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Làm sao để hoàn tác import?" MaxHeight="300">
                            <MudText Typo="Typo.body2">Vào trang Import → Nhấn "Lịch sử Import" → Tìm phiên import cần hoàn tác → Nhấn "Rollback". Dữ liệu sẽ khôi phục về trạng thái trước khi import.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Trùng hộ chiếu khi import?" MaxHeight="300">
                            <MudText Typo="Typo.body2">Hệ thống tự phát hiện hộ chiếu trùng ở Bước 3. Bạn có thể chọn "Cập nhật" (ghi đè dữ liệu cũ) hoặc "Bỏ qua" cho từng dòng.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Nhập thủ công thay vì dùng Excel?" MaxHeight="300">
                            <MudText Typo="Typo.body2">Trong trang Import, nhấn nút "✏️ Nhập thủ công" ở góc trên phải. Form sẽ hiển thị để bạn nhập từng nhân viên trực tiếp.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Xuất báo cáo theo bộ lọc?" MaxHeight="300">
                            <MudText Typo="Typo.body2">Vào Báo cáo → Chọn bộ lọc (GPLĐ, quốc tịch, sắp hết hạn) → Nhấn "Xem trước" → Nhấn "Xuất Excel". File xuất sẽ chỉ chứa dữ liệu đã lọc.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="NLĐ sắp hết hạn được tính thế nào?" MaxHeight="300">
                            <MudText Typo="Typo.body2">Hệ thống so sánh ngày "Hạn tạm trú" với ngày hiện tại. NLĐ có hạn ≤30 ngày sẽ được đánh dấu cảnh báo trên Dashboard và trong danh sách.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Xóa nhân viên có mất dữ liệu không?" MaxHeight="200">
                            <MudText Typo="Typo.body2">Không. Hệ thống sử dụng "xóa mềm" — dữ liệu chỉ bị ẩn và có thể phục hồi từ trang Quản trị.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Hệ thống hỗ trợ file .xls không?" MaxHeight="200">
                            <MudText Typo="Typo.body2">Có. Hệ thống hỗ trợ cả .xlsx (Excel 2007+) và .xls (Excel 97-2003) cho cả import và export.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Tìm kiếm hoạt động thế nào?" MaxHeight="300">
                            <MudText Typo="Typo.body2">Full-text search tìm trên tất cả các trường: tên, hộ chiếu, visa, GPLĐ, công ty, quốc tịch, nghề nghiệp, người thân. Có thể lọc theo NV hoặc Công ty.</MudText>
                        </MudExpansionPanel>
                        <MudExpansionPanel Text="Liên hệ hỗ trợ kỹ thuật?" MaxHeight="200">
                            <MudText Typo="Typo.body2">Email: support@irm.vn · ĐT: 0123.456.789</MudText>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudContainer>
            </MudTabPanel>
        </MudTabs>
    </MudDrawer>
}

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _helpOpen;
    private bool _isLoggedIn;
    private string _pageTitle = "Dashboard";
    private string _breadcrumbText = "Dashboard";
    private string? _topSearchQuery;

    private LoginModel _loginModel = new() { Username = "admin", Password = "" };
    private string? _loginError;

    private class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }

    private static readonly Dictionary<string, string> _breadcrumbs = new()
    {
        { "Dashboard", "Dashboard" },
        { "Quản lý Công ty", "Quản lý dữ liệu / Công ty" },
        { "Quản lý Nhân viên", "Quản lý dữ liệu / Nhân viên" },
        { "Import Excel", "Quản lý dữ liệu / Import Excel" },
        { "Tìm kiếm", "Phân tích & Báo cáo / Tìm kiếm" },
        { "Báo cáo", "Phân tích & Báo cáo / Báo cáo" },
        { "Quản trị", "Quản trị" }
    };

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#2563eb",
            PrimaryDarken = "#1d4ed8",
            PrimaryLighten = "#60a5fa",
            Secondary = "#6366f1",
            Tertiary = "#7c3aed",
            Info = "#2563eb",
            Success = "#059669",
            Warning = "#d97706",
            Error = "#dc2626",
            Background = "#f0f4f8",
            Surface = "#ffffff",
            AppbarBackground = "rgba(255,255,255,0.85)",
            AppbarText = "#1a2332",
            DrawerBackground = "#0f172a",
            DrawerText = "rgba(255,255,255,0.7)",
            DrawerIcon = "rgba(255,255,255,0.5)",
            TextPrimary = "#1a2332",
            TextSecondary = "#5a6a7e",
            ActionDefault = "#5a6a7e",
            Divider = "#e2e8f0",
            DividerLight = "#f1f5f9",
            TableHover = "#f0f6ff"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#8ab4f8",
            PrimaryDarken = "#6d9cf7",
            PrimaryLighten = "#aecbfa",
            Secondary = "#c4b5fd",
            Tertiary = "#a78bfa",
            Info = "#8ab4f8",
            Success = "#34d399",
            Warning = "#fbbf24",
            Error = "#f87171",
            Background = "#111318",
            Surface = "#1c1f26",
            AppbarBackground = "rgba(28,31,38,0.9)",
            AppbarText = "#e4e6eb",
            DrawerBackground = "#0d1017",
            DrawerText = "rgba(255,255,255,0.6)",
            DrawerIcon = "rgba(255,255,255,0.4)",
            TextPrimary = "#e4e6eb",
            TextSecondary = "#9aa0a6",
            ActionDefault = "#9aa0a6",
            Divider = "#2d3139",
            DividerLight = "#22252d",
            TableHover = "rgba(130,177,255,0.06)"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "10px",
            DrawerWidthLeft = "256px",
            DrawerMiniWidthLeft = "68px"
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Restore login state from session
            try
            {
                var result = await SessionStore.GetAsync<bool>("irm_logged_in");
                if (result.Success && result.Value && !_isLoggedIn)
                {
                    _isLoggedIn = true;
                    StateHasChanged();
                }
            }
            catch { /* First visit, no session */ }

            // Init theme from localStorage
            var savedTheme = await JS.InvokeAsync<string>("irmInterop.initTheme");
            if (savedTheme == "dark" && !_isDarkMode)
            {
                _isDarkMode = true;
                StateHasChanged();
            }

            // Hide loading screen
            await JS.InvokeVoidAsync("irmInterop.hideLoadingScreen");
        }
    }

    private async Task HandleLogin()
    {
        if (_loginModel.Password != "demo")
        {
            _loginError = "❌ Sai mật khẩu. Mật khẩu mặc định: demo";
            return;
        }
        _loginError = null;
        _isLoggedIn = true;
        try { await SessionStore.SetAsync("irm_logged_in", true); } catch { }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("irmInterop.setTheme", _isDarkMode ? "dark" : "light");
        try { await JS.InvokeVoidAsync("irmInterop.refreshCharts"); } catch { }
    }

    private void ToggleHelp() => _helpOpen = !_helpOpen;

    private void OnPageChanged(string title)
    {
        _pageTitle = title;
        _breadcrumbText = _breadcrumbs.GetValueOrDefault(title, title);
    }

    private void OnTopSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_topSearchQuery))
        {
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_topSearchQuery)}");
            _topSearchQuery = "";
        }
    }

    private async Task Logout()
    {
        _isLoggedIn = false;
        try { await SessionStore.DeleteAsync("irm_logged_in"); } catch { }
    }
}
