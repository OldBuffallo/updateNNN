@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="irm-shell">
    <MudAppBar Elevation="0" Dense="true" Class="irm-topbar">
        <div class="topbar-left">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           Class="topbar-icon-btn"
                           OnClick="@ToggleDrawer" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.subtitle1" Class="topbar-title">@_pageTitle</MudText>
                <span class="irm-breadcrumb">
                    <a href="/">Trang chu</a> / @_breadcrumbText
                </span>
            </MudStack>
        </div>

        <MudSpacer />

        <div class="topbar-right">
            <MudTextField T="string"
                          Placeholder="Tim nhanh... (Ctrl+K)"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Margin="Margin.Dense"
                          Class="topbar-search" />

            <MudBadge Dot="true" Color="Color.Error" Overlap="true">
                <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone"
                               Color="Color.Inherit"
                               Class="topbar-icon-btn" />
            </MudBadge>

            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           Class="topbar-icon-btn"
                           OnClick="@ToggleDarkMode" />

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.HelpOutline"
                       Class="topbar-help-btn"
                       OnClick="@ToggleHelp">
                Ho tro
            </MudButton>
        </div>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="2"
               ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Mini"
               OpenMiniOnHover="false"
               Class="irm-drawer">
        <MudDrawerHeader Dense="true" Class="irm-drawer-header">
            <div class="sidebar-logo-mark">
                <MudIcon Icon="@Icons.Material.Filled.FactCheck"
                         Color="Color.Inherit"
                         Size="Size.Medium" />
            </div>

            @if (_drawerOpen)
            {
                <MudStack Spacing="0" Class="sidebar-brand-copy">
                    <MudText Typo="Typo.subtitle1" Class="sidebar-brand-title">IRM</MudText>
                    <MudText Typo="Typo.caption" Class="sidebar-brand-badge">v2.0</MudText>
                </MudStack>
            }
        </MudDrawerHeader>

        <NavMenu OnPageChanged="@OnPageChanged" />

        <MudSpacer />

        <div class="user-footer">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="user-footer-row">
                <div class="user-avatar">A</div>

                @if (_drawerOpen)
                {
                    <MudStack Spacing="0" Class="user-footer-copy">
                        <MudText Typo="Typo.body2" Class="user-footer-name">Admin</MudText>
                        <MudText Typo="Typo.caption" Class="user-footer-role">Quan tri vien</MudText>
                    </MudStack>

                    <MudIconButton Icon="@Icons.Material.Filled.Logout"
                                   Size="Size.Small"
                                   Class="user-footer-logout"
                                   OnClick="@Logout" />
                }
            </MudStack>
        </div>
    </MudDrawer>

    <MudMainContent Class="irm-main">
        <MudContainer MaxWidth="MaxWidth.False" Class="irm-main-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<MudDrawer @bind-Open="_helpOpen"
           Anchor="Anchor.End"
           Elevation="3"
           Width="380px"
           Variant="DrawerVariant.Temporary"
           Class="help-drawer">
    <MudDrawerHeader Class="help-drawer-header">
        <MudText Typo="Typo.h6" Class="help-drawer-title">Ho tro su dung</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       OnClick="@ToggleHelp"
                       Size="Size.Small"
                       Class="help-close-btn" />
    </MudDrawerHeader>

    <MudDivider />

    <MudTabs Rounded="true" Centered="true" Class="help-tabs">
        <MudTabPanel Text="Trang hien tai" Icon="@Icons.Material.Filled.Info">
            <MudContainer Class="pa-4">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Color="Color.Primary" Class="mb-2">@_pageTitle</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Day la trang @_pageTitle. Su dung cac chuc nang tren trang de quan ly du lieu lao dong nuoc ngoai.
                </MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">
                    <strong>Meo:</strong> Nhan <strong>Ctrl+K</strong> de tim kiem nhanh tu bat ky trang nao.
                </MudAlert>
            </MudContainer>
        </MudTabPanel>

        <MudTabPanel Text="Phim tat" Icon="@Icons.Material.Filled.Keyboard">
            <MudSimpleTable Dense="true" Hover="true" Class="ma-4">
                <thead>
                    <tr>
                        <th>Chuc nang</th>
                        <th>Phim tat</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>Tim kiem nhanh</td><td><MudChip T="string" Size="Size.Small">Ctrl + K</MudChip></td></tr>
                    <tr><td>Mo ho tro</td><td><MudChip T="string" Size="Size.Small">F1</MudChip></td></tr>
                    <tr><td>Ve Dashboard</td><td><MudChip T="string" Size="Size.Small">Ctrl + H</MudChip></td></tr>
                    <tr><td>Them moi</td><td><MudChip T="string" Size="Size.Small">Ctrl + N</MudChip></td></tr>
                </tbody>
            </MudSimpleTable>
        </MudTabPanel>

        <MudTabPanel Text="FAQ" Icon="@Icons.Material.Filled.QuestionAnswer">
            <MudContainer Class="pa-4">
                <MudExpansionPanels MultiExpansion="true">
                    <MudExpansionPanel Text="Toi quen mat khau?" MaxHeight="200">
                        <MudText Typo="Typo.body2">Lien he quan tri vien de dat lai. Vao Quan tri -> Tai khoan -> Dat lai mat khau.</MudText>
                    </MudExpansionPanel>
                    <MudExpansionPanel Text="File Excel import bi loi?" MaxHeight="200">
                        <MudText Typo="Typo.body2">Dam bao file dung dinh dang .xlsx. Dong dau tien phai la tieu de cot.</MudText>
                    </MudExpansionPanel>
                    <MudExpansionPanel Text="Lien he ho tro ky thuat?" MaxHeight="200">
                        <MudText Typo="Typo.body2">Email: support@irm.vn - DT: 0123.456.789</MudText>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudContainer>
        </MudTabPanel>
    </MudTabs>
</MudDrawer>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _helpOpen;
    private string _pageTitle = "Dashboard";
    private string _breadcrumbText = "Dashboard";

    private static readonly Dictionary<string, string> _breadcrumbs = new()
    {
        { "Dashboard", "Dashboard" },
        { "Quan ly Cong ty", "Quan ly du lieu / Cong ty" },
        { "Quan ly Nhan vien", "Quan ly du lieu / Nhan vien" },
        { "Import Excel", "Quan ly du lieu / Import Excel" },
        { "Tim kiem", "Phan tich va Bao cao / Tim kiem" },
        { "Bao cao", "Phan tich va Bao cao / Bao cao" },
        { "Quan tri", "Quan tri" }
    };

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#2563eb",
            PrimaryDarken = "#1d4ed8",
            PrimaryLighten = "#60a5fa",
            Secondary = "#6366f1",
            Tertiary = "#7c3aed",
            Info = "#2563eb",
            Success = "#059669",
            Warning = "#d97706",
            Error = "#dc2626",
            Background = "#f0f4f8",
            Surface = "#ffffff",
            AppbarBackground = "rgba(255,255,255,0.85)",
            AppbarText = "#1a2332",
            DrawerBackground = "#0f172a",
            DrawerText = "rgba(255,255,255,0.7)",
            DrawerIcon = "rgba(255,255,255,0.5)",
            TextPrimary = "#1a2332",
            TextSecondary = "#5a6a7e",
            ActionDefault = "#5a6a7e",
            Divider = "#e2e8f0",
            DividerLight = "#f1f5f9",
            TableHover = "#f0f6ff"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#8ab4f8",
            PrimaryDarken = "#6d9cf7",
            PrimaryLighten = "#aecbfa",
            Secondary = "#c4b5fd",
            Tertiary = "#a78bfa",
            Info = "#8ab4f8",
            Success = "#34d399",
            Warning = "#fbbf24",
            Error = "#f87171",
            Background = "#111318",
            Surface = "#1c1f26",
            AppbarBackground = "rgba(28,31,38,0.9)",
            AppbarText = "#e4e6eb",
            DrawerBackground = "#0d1017",
            DrawerText = "rgba(255,255,255,0.6)",
            DrawerIcon = "rgba(255,255,255,0.4)",
            TextPrimary = "#e4e6eb",
            TextSecondary = "#9aa0a6",
            ActionDefault = "#9aa0a6",
            Divider = "#2d3139",
            DividerLight = "#22252d",
            TableHover = "rgba(130,177,255,0.06)"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "10px",
            DrawerWidthLeft = "256px",
            DrawerMiniWidthLeft = "68px"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
    private void ToggleHelp() => _helpOpen = !_helpOpen;

    private void OnPageChanged(string title)
    {
        _pageTitle = title;
        _breadcrumbText = _breadcrumbs.GetValueOrDefault(title, title);
    }

    private void Logout()
    {
        // UI-only for now.
    }
}
