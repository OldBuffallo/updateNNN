@using Microsoft.AspNetCore.Components.Routing

<MudNavMenu Class="irm-nav-menu">
    <MudText Typo="Typo.overline" Class="nav-section-title">Tong quan</MudText>
    <MudNavLink Href="/"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Dashboard"))'>
        Dashboard
    </MudNavLink>

    <MudText Typo="Typo.overline" Class="nav-section-title">Quan ly du lieu</MudText>
    <MudNavLink Href="/companies"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Business"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Quan ly Cong ty"))'>
        Cong ty
    </MudNavLink>
    <MudNavLink Href="/employees"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Groups"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Quan ly Nhan vien"))'>
        Nhan vien
    </MudNavLink>
    <MudNavLink Href="/import"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.UploadFile"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Import Excel"))'>
        <span>Import Excel</span>
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="nav-link-badge">Moi</MudChip>
    </MudNavLink>

    <MudText Typo="Typo.overline" Class="nav-section-title">Phan tich va bao cao</MudText>
    <MudNavLink Href="/search"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Search"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Tim kiem"))'>
        <span>Tim kiem</span>
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="nav-link-badge">Moi</MudChip>
    </MudNavLink>
    <MudNavLink Href="/reports"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Assessment"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Bao cao"))'>
        <span>Bao cao</span>
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="nav-link-badge">Moi</MudChip>
    </MudNavLink>

    <MudDivider Class="nav-divider" />

    <MudNavLink Href="/admin"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Settings"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Quan tri"))'>
        Quan tri
    </MudNavLink>
</MudNavMenu>

@code {
    [Parameter]
    public EventCallback<string> OnPageChanged { get; set; }

    private async Task NotifyPageChanged(string title)
    {
        await OnPageChanged.InvokeAsync(title);
    }
}
