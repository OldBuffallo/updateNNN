@using Microsoft.AspNetCore.Components.Routing

<MudNavMenu Class="irm-nav-menu">
    <MudText Typo="Typo.overline" Class="nav-section-title">Tổng quan</MudText>
    <MudNavLink Href="/"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Dashboard"))'>
        Dashboard
    </MudNavLink>

    <MudText Typo="Typo.overline" Class="nav-section-title">Quản lý dữ liệu</MudText>
    <MudNavLink Href="/companies"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Business"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Quản lý Công ty"))'>
        Công ty
    </MudNavLink>
    <MudNavLink Href="/employees"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Groups"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Quản lý Nhân viên"))'>
        Nhân viên
    </MudNavLink>
    <MudNavLink Href="/students"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.School"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Quản lý Du học sinh"))'>
        Du học sinh
    </MudNavLink>
    <MudNavLink Href="/import"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.UploadFile"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Import Excel"))'>
        <span>Import Excel</span>
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="nav-link-badge">Mới</MudChip>
    </MudNavLink>

    <MudText Typo="Typo.overline" Class="nav-section-title">Phân tích & báo cáo</MudText>
    <MudNavLink Href="/search"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Search"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Tìm kiếm"))'>
        <span>Tìm kiếm</span>
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="nav-link-badge">Mới</MudChip>
    </MudNavLink>
    <MudNavLink Href="/reports"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Assessment"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Báo cáo"))'>
        <span>Báo cáo</span>
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="nav-link-badge">Mới</MudChip>
    </MudNavLink>

    <MudDivider Class="nav-divider" />

    <MudNavLink Href="/admin"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Settings"
                Class="irm-nav-link"
                ActiveClass="active"
                OnClick='@(() => NotifyPageChanged("Quản trị"))'>
        Quản trị
    </MudNavLink>
</MudNavMenu>

@code {
    [Parameter]
    public EventCallback<string> OnPageChanged { get; set; }

    private async Task NotifyPageChanged(string title)
    {
        await OnPageChanged.InvokeAsync(title);
    }
}
