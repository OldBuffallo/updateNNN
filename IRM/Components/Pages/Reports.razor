@page "/reports"

<PageTitle>Bao cao - IRM v2.0</PageTitle>

<div class="section-header" style="border-bottom:none; padding-bottom:0; margin-bottom:8px;">
    <h3>Tao bao cao tuy chinh</h3>
</div>

<div class="report-builder-grid">
    <div class="report-builder-sidebar">
        <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 700;">Cau hinh bao cao</MudText>

        <div class="mb-4">
            <span class="builder-section-title">Nguon du lieu</span>
            <MudSelect T="string" Variant="Variant.Outlined" Value="@("all")" FullWidth="true">
                <MudSelectItem Value="@("all")">Nhan vien + Cong ty</MudSelectItem>
                <MudSelectItem Value="@("company")">Chi Cong ty</MudSelectItem>
                <MudSelectItem Value="@("employee")">Chi Nhan vien</MudSelectItem>
            </MudSelect>
        </div>

        <div class="mb-4">
            <span class="builder-section-title">Chon cot hien thi</span>
            @foreach (var col in _columns)
            {
                <MudCheckBox T="bool"
                             @bind-Value="col.Selected"
                             Label="@col.Name"
                             Dense="true"
                             Color="Color.Primary" />
            }
        </div>

        <MudDivider Class="my-4" />

        <div class="mb-4">
            <span class="builder-section-title">Nhom theo</span>
            <MudSelect T="string" Variant="Variant.Outlined" Value="@("company")" FullWidth="true">
                <MudSelectItem Value="@("company")">Cong ty</MudSelectItem>
                <MudSelectItem Value="@("nationality")">Quoc tich</MudSelectItem>
                <MudSelectItem Value="@("field")">Linh vuc</MudSelectItem>
            </MudSelect>
        </div>

        <MudDivider Class="my-4" />

        <MudStack Spacing="1">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Download">
                Xuat Excel
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.PictureAsPdf">
                Xuat PDF
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Save">
                Luu Template
            </MudButton>
        </MudStack>
    </div>

    <div class="report-builder-preview">
        <div class="chart-header">
            <h3>Xem truoc: BC NLD sap het han tam tru</h3>
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">23 ban ghi</MudChip>
        </div>

        <MudSimpleTable Dense="true" Hover="true" Striped="true">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Cong ty</th>
                    <th>Ho ten</th>
                    <th>Quoc tich</th>
                    <th>Ho chieu</th>
                    <th>Nghe nghiep</th>
                    <th>GPLD</th>
                    <th>Han TT</th>
                    <th>Con lai</th>
                </tr>
            </thead>
            <tbody>
                <tr class="group-header">
                    <td colspan="9"><strong>🏢 Cty TNHH Samsung Electronics VN</strong></td>
                </tr>
                <tr><td>1</td><td></td><td>Zhang Wei</td><td>Trung Quoc</td><td>E12345678</td><td>Ky su</td><td><span class="tag tag-green">Co GPLD</span></td><td>18/04/2026</td><td class="text-danger"><strong>3 ngay</strong></td></tr>
                <tr><td>2</td><td></td><td>Kim Min-jun</td><td>Han Quoc</td><td>M55667788</td><td>Quan ly</td><td><span class="tag tag-green">Co GPLD</span></td><td>20/04/2026</td><td class="text-danger"><strong>5 ngay</strong></td></tr>
                <tr class="group-header">
                    <td colspan="9"><strong>🏢 Cty CP Hyundai Aluminum Vina</strong></td>
                </tr>
                <tr><td>3</td><td></td><td>Park Ji-hoon</td><td>Han Quoc</td><td>M99887766</td><td>Ky thuat</td><td><span class="tag tag-green">Co GPLD</span></td><td>03/05/2026</td><td class="text-warning"><strong>18 ngay</strong></td></tr>
                <tr><td>4</td><td></td><td>Wang Li</td><td>Trung Quoc</td><td>E98765432</td><td>Quan ly</td><td><span class="tag tag-green">Co GPLD</span></td><td>10/05/2026</td><td class="text-info"><strong>25 ngay</strong></td></tr>
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mt-8 mb-3">Template da luu</MudText>
        <MudStack Spacing="2">
            @foreach (var tpl in _templates)
            {
                <div class="template-item">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
                    <div class="template-item-body">
                        <MudText Typo="Typo.body2" Class="template-item-title">@tpl.Name</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@tpl.Meta</MudText>
                    </div>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary">Chay</MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small">Sua</MudButton>
                </div>
            }
        </MudStack>
    </div>
</div>

@code {
    private class ColumnOption
    {
        public string Name { get; set; } = "";
        public bool Selected { get; set; }
    }

    private readonly List<ColumnOption> _columns = new()
    {
        new() { Name = "Cong ty", Selected = true },
        new() { Name = "Ho ten", Selected = true },
        new() { Name = "Quoc tich", Selected = true },
        new() { Name = "Ho chieu", Selected = true },
        new() { Name = "Nghe nghiep", Selected = true },
        new() { Name = "Loai GPLD", Selected = true },
        new() { Name = "Han tam tru", Selected = true },
        new() { Name = "Gioi tinh", Selected = false },
        new() { Name = "Ngay sinh", Selected = false },
        new() { Name = "Con lai (ngay)", Selected = true }
    };

    private record TemplateItem(string Name, string Meta);

    private readonly List<TemplateItem> _templates = new()
    {
        new("BC NLD sap het han tam tru", "23 ban ghi · Hom nay"),
        new("BC NLD theo quoc tich", "1,245 ban ghi · 15/04"),
        new("BC thong ke theo linh vuc", "156 cong ty · 10/04")
    };
}
