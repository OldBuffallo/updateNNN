@page "/reports"

<PageTitle>Báo cáo - IRM v2.0</PageTitle>

<div class="section-header" style="border-bottom:none; padding-bottom:0; margin-bottom:8px;">
    <h3>Tạo báo cáo tùy chỉnh</h3>
</div>

<div class="report-builder-grid">
    <div class="report-builder-sidebar">
        <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 700;">Cấu hình báo cáo</MudText>

        <div class="mb-4">
            <span class="builder-section-title">Nguồn dữ liệu</span>
            <MudSelect T="string" Variant="Variant.Outlined" Value="@("all")" FullWidth="true">
                <MudSelectItem Value="@("all")">Nhân viên + Công ty</MudSelectItem>
                <MudSelectItem Value="@("company")">Chỉ Công ty</MudSelectItem>
                <MudSelectItem Value="@("employee")">Chỉ Nhân viên</MudSelectItem>
            </MudSelect>
        </div>

        <div class="mb-4">
            <span class="builder-section-title">Chọn cột hiển thị</span>
            @foreach (var col in _columns)
            {
                <MudCheckBox T="bool"
                             @bind-Value="col.Selected"
                             Label="@col.Name"
                             Dense="true"
                             Color="Color.Primary" />
            }
        </div>

        <MudDivider Class="my-4" />

        <div class="mb-4">
            <span class="builder-section-title">Nhóm theo</span>
            <MudSelect T="string" Variant="Variant.Outlined" Value="@("company")" FullWidth="true">
                <MudSelectItem Value="@("company")">Công ty</MudSelectItem>
                <MudSelectItem Value="@("nationality")">Quốc tịch</MudSelectItem>
                <MudSelectItem Value="@("field")">Lĩnh vực</MudSelectItem>
            </MudSelect>
        </div>

        <MudDivider Class="my-4" />

        <MudStack Spacing="1">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Download">
                Xuất Excel
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.PictureAsPdf">
                Xuất PDF
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Save">
                Lưu Template
            </MudButton>
        </MudStack>
    </div>

    <div class="report-builder-preview">
        <div class="chart-header">
            <h3>Xem trước: BC NLĐ sắp hết hạn tạm trú</h3>
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">23 bản ghi</MudChip>
        </div>

        <MudSimpleTable Dense="true" Hover="true" Striped="true">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Công ty</th>
                    <th>Họ tên</th>
                    <th>Quốc tịch</th>
                    <th>Hộ chiếu</th>
                    <th>Nghề nghiệp</th>
                    <th>GPLĐ</th>
                    <th>Hạn TT</th>
                    <th>Còn lại</th>
                </tr>
            </thead>
            <tbody>
                <tr class="group-header">
                    <td colspan="9"><strong>Cty TNHH Samsung Electronics VN</strong></td>
                </tr>
                <tr><td>1</td><td></td><td>Zhang Wei</td><td>Trung Quốc</td><td>E12345678</td><td>Kỹ sư</td><td><span class="tag tag-green">Có GPLĐ</span></td><td>18/04/2026</td><td class="text-danger"><strong>3 ngày</strong></td></tr>
                <tr><td>2</td><td></td><td>Kim Min-jun</td><td>Hàn Quốc</td><td>M55667788</td><td>Quản lý</td><td><span class="tag tag-green">Có GPLĐ</span></td><td>20/04/2026</td><td class="text-danger"><strong>5 ngày</strong></td></tr>
                <tr class="group-header">
                    <td colspan="9"><strong>Cty CP Hyundai Aluminum Vina</strong></td>
                </tr>
                <tr><td>3</td><td></td><td>Park Ji-hoon</td><td>Hàn Quốc</td><td>M99887766</td><td>Kỹ thuật</td><td><span class="tag tag-green">Có GPLĐ</span></td><td>03/05/2026</td><td class="text-warning"><strong>18 ngày</strong></td></tr>
                <tr><td>4</td><td></td><td>Wang Li</td><td>Trung Quốc</td><td>E98765432</td><td>Quản lý</td><td><span class="tag tag-green">Có GPLĐ</span></td><td>10/05/2026</td><td class="text-info"><strong>25 ngày</strong></td></tr>
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mt-8 mb-3">Template đã lưu</MudText>
        <MudStack Spacing="2">
            @foreach (var tpl in _templates)
            {
                <div class="template-item">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
                    <div class="template-item-body">
                        <MudText Typo="Typo.body2" Class="template-item-title">@tpl.Name</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@tpl.Meta</MudText>
                    </div>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary">Chạy</MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small">Sửa</MudButton>
                </div>
            }
        </MudStack>
    </div>
</div>

@code {
    private class ColumnOption
    {
        public string Name { get; set; } = "";
        public bool Selected { get; set; }
    }

    private readonly List<ColumnOption> _columns = new()
    {
        new() { Name = "Công ty", Selected = true },
        new() { Name = "Họ tên", Selected = true },
        new() { Name = "Quốc tịch", Selected = true },
        new() { Name = "Hộ chiếu", Selected = true },
        new() { Name = "Nghề nghiệp", Selected = true },
        new() { Name = "Loại GPLĐ", Selected = true },
        new() { Name = "Hạn tạm trú", Selected = true },
        new() { Name = "Giới tính", Selected = false },
        new() { Name = "Ngày sinh", Selected = false },
        new() { Name = "Còn lại (ngày)", Selected = true }
    };

    private record TemplateItem(string Name, string Meta);

    private readonly List<TemplateItem> _templates = new()
    {
        new("BC NLĐ sắp hết hạn tạm trú", "23 bản ghi · Hôm nay"),
        new("BC NLĐ theo quốc tịch", "1,245 bản ghi · 15/04"),
        new("BC thống kê theo lĩnh vực", "156 công ty · 10/04")
    };
}
