@page "/admin"

@using IRM.Services
@using IRM.Data.Models
@inject AuthService AuthSvc
@inject AuditService AuditSvc
@inject CatalogService CatalogSvc

<PageTitle>Quan tri - IRM v2.0</PageTitle>

<div class="section-header">
    <h3>Quan tri he thong</h3>
    <span class="section-meta">Quan ly danh muc va cau hinh he thong</span>
</div>

<div class="admin-grid">
    @foreach (var card in _adminCards)
    {
        <div class="admin-card">
            <div class="admin-icon">@card.Icon</div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:700;">@card.Title</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@card.Description</MudText>
        </div>
    }
</div>

@code {
    private record AdminCard(string Icon, string Title, string Description);

    private List<AdminCard> _adminCards = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var accounts = await AuthSvc.GetAllAccountsAsync();
            var fields = await CatalogSvc.GetFieldsAsync();
            var careers = await CatalogSvc.GetCareersAsync();
            var nationalities = await CatalogSvc.GetNationalitiesAsync();
            var districts = await CatalogSvc.GetDistrictsAsync();
            var wards = await CatalogSvc.GetWardsAsync();
            await AuditSvc.GetRecentAsync(1);

            _adminCards = new()
            {
                new("👤", "Tai khoan", $"{accounts.Count} tai khoan hoat dong"),
                new("🏭", "Linh vuc", $"{fields.Count} linh vuc"),
                new("💼", "Nganh nghe", $"{careers.Count} nganh"),
                new("🌍", "Quoc tich", $"{nationalities.Count} quoc tich"),
                new("🗺️", "Quan / Huyen", $"{districts.Count} quan huyen"),
                new("📍", "Phuong / Xa", $"{wards.Count} phuong xa"),
                new("📜", "Nhat ky he thong", "Audit Log"),
                new("📤", "Lich su Import", "Import History")
            };
        }
        catch
        {
            _adminCards = new()
            {
                new("👤", "Tai khoan", "Chua ket noi DB"),
                new("🏭", "Linh vuc", "Chua ket noi DB"),
                new("💼", "Nganh nghe", "Chua ket noi DB"),
                new("🌍", "Quoc tich", "Chua ket noi DB"),
                new("🗺️", "Quan / Huyen", "Chua ket noi DB"),
                new("📍", "Phuong / Xa", "Chua ket noi DB"),
                new("📜", "Nhat ky", "Chua ket noi DB"),
                new("📤", "Import", "Chua ket noi DB")
            };
        }
    }
}
