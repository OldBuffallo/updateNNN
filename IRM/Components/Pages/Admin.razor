@page "/admin"

@using IRM.Services
@inject AuthService AuthSvc
@inject AuditService AuditSvc
@inject CatalogService CatalogSvc

<PageTitle>Quản trị - IRM v2.0</PageTitle>

<div class="section-header">
    <h3>Quản trị hệ thống</h3>
    <span class="section-meta">Quản lý danh mục và cấu hình hệ thống</span>
</div>

<div class="admin-grid">
    @foreach (var card in _adminCards)
    {
        <div class="admin-card">
            <MudIcon Icon="@card.Icon" Class="admin-icon" />
            <MudText Typo="Typo.subtitle1" Style="font-weight:700;">@card.Title</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@card.Description</MudText>
        </div>
    }
</div>

@code {
    private record AdminCard(string Icon, string Title, string Description);

    private List<AdminCard> _adminCards = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var accounts = await AuthSvc.GetAllAccountsAsync();
            var fields = await CatalogSvc.GetFieldsAsync();
            var careers = await CatalogSvc.GetCareersAsync();
            var nationalities = await CatalogSvc.GetNationalitiesAsync();
            var districts = await CatalogSvc.GetDistrictsAsync();
            var wards = await CatalogSvc.GetWardsAsync();
            await AuditSvc.GetRecentAsync(1);

            _adminCards = new()
            {
                new(Icons.Material.Filled.ManageAccounts, "Tài khoản", $"{accounts.Count} tài khoản hoạt động"),
                new(Icons.Material.Filled.Business, "Lĩnh vực", $"{fields.Count} lĩnh vực"),
                new(Icons.Material.Filled.Work, "Ngành nghề", $"{careers.Count} ngành"),
                new(Icons.Material.Filled.Public, "Quốc tịch", $"{nationalities.Count} quốc tịch"),
                new(Icons.Material.Filled.Map, "Quận / Huyện", $"{districts.Count} quận huyện"),
                new(Icons.Material.Filled.Place, "Phường / Xã", $"{wards.Count} phường xã"),
                new(Icons.Material.Filled.ReceiptLong, "Nhật ký hệ thống", "Audit Log"),
                new(Icons.Material.Filled.CloudUpload, "Lịch sử Import", "Import History")
            };
        }
        catch
        {
            _adminCards = new()
            {
                new(Icons.Material.Filled.ManageAccounts, "Tài khoản", "Chưa kết nối DB"),
                new(Icons.Material.Filled.Business, "Lĩnh vực", "Chưa kết nối DB"),
                new(Icons.Material.Filled.Work, "Ngành nghề", "Chưa kết nối DB"),
                new(Icons.Material.Filled.Public, "Quốc tịch", "Chưa kết nối DB"),
                new(Icons.Material.Filled.Map, "Quận / Huyện", "Chưa kết nối DB"),
                new(Icons.Material.Filled.Place, "Phường / Xã", "Chưa kết nối DB"),
                new(Icons.Material.Filled.ReceiptLong, "Nhật ký", "Chưa kết nối DB"),
                new(Icons.Material.Filled.CloudUpload, "Import", "Chưa kết nối DB")
            };
        }
    }
}
