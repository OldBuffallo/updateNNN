@page "/"

@using IRM.Services
@using Microsoft.AspNetCore.Components.Web
@inject DashboardService DashboardSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Dashboard - IRM v2.0</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Chưa kết nối được database: @_error - Hiển thị dữ liệu mẫu.
    </MudAlert>
}

<div class="section-header">
    <h3>📊 Tổng quan hệ thống</h3>
    <span class="section-meta">Dữ liệu cập nhật: Hôm nay, @DateTime.Now.ToString("dd/MM/yyyy")</span>
</div>

<div class="kpi-grid">
    <div class="kpi-card kpi-blue kpi-card-action" role="button" tabindex="0"
         @onclick='() => GoTo("/companies")' @onkeydown='e => OnCardKeyDown(e, "/companies")'>
        <div>
            <span class="kpi-label">Tổng công ty</span>
            <span class="kpi-value" id="kpiCompanies">@_totalCompanies.ToString("N0")</span>
            <span class="kpi-change up">▲ +@_newCompaniesThisMonth tháng này</span>
        </div>
        <div class="kpi-icon">🏢</div>
    </div>

    <div class="kpi-card kpi-green kpi-card-action" role="button" tabindex="0"
         @onclick='() => GoTo("/employees")' @onkeydown='e => OnCardKeyDown(e, "/employees")'>
        <div>
            <span class="kpi-label">Tổng lao động NN</span>
            <span class="kpi-value" id="kpiEmployees">@_totalEmployees.ToString("N0")</span>
            <span class="kpi-change up">▲ +@_newEmployeesThisMonth tháng này</span>
        </div>
        <div class="kpi-icon">👥</div>
    </div>

    <div class="kpi-card kpi-orange kpi-card-action" role="button" tabindex="0"
         @onclick='() => GoTo("/employees")' @onkeydown='e => OnCardKeyDown(e, "/employees")'>
        <div>
            <span class="kpi-label">Sắp hết hạn tạm trú</span>
            <span class="kpi-value" id="kpiExpiring">@_expiringCount</span>
            <span class="kpi-change warn">⚠ Trong 30 ngày tới</span>
        </div>
        <div class="kpi-icon">⚠️</div>
    </div>

    <div class="kpi-card kpi-purple kpi-card-action" role="button" tabindex="0"
         @onclick='() => GoTo("/employees")' @onkeydown='e => OnCardKeyDown(e, "/employees")'>
        <div>
            <span class="kpi-label">Đã có GPLĐ</span>
            <span class="kpi-value" id="kpiPermit">@_withPermit.ToString("N0")</span>
            <span class="kpi-change up">@(_totalEmployees > 0 ? $"{(double)_withPermit / _totalEmployees * 100:F1}% tổng số" : "-")</span>
        </div>
        <div class="kpi-icon">📋</div>
    </div>
</div>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="12" md="7">
        <div class="chart-card chart-card-action" role="button" tabindex="0"
             @onclick='() => GoTo("/employees")' @onkeydown='e => OnCardKeyDown(e, "/employees")'>
            <div class="chart-header">
                <h4>Lao động nước ngoài theo quốc tịch</h4>
                <MudSelect T="string" Value="@_chartYear" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Style="max-width: 140px;" Dense="true">
                    <MudSelectItem Value="@("2026")">Năm 2026</MudSelectItem>
                    <MudSelectItem Value="@("2025")">Năm 2025</MudSelectItem>
                </MudSelect>
            </div>
            <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_nationalitySeries"
                      XAxisLabels="@_nationalityLabels" Width="100%" Height="260px"
                      ChartOptions="@(new ChartOptions { ChartPalette = _barColors })" />
        </div>
    </MudItem>
    <MudItem xs="12" md="5">
        <div class="chart-card chart-card-action" role="button" tabindex="0"
             @onclick='() => GoTo("/reports")' @onkeydown='e => OnCardKeyDown(e, "/reports")'>
            <div class="chart-header">
                <h4>Tỷ lệ giấy phép lao động</h4>
            </div>
            <MudChart T="double" ChartType="ChartType.Donut" InputData="@_permitData"
                      InputLabels="@_permitLabels" Width="100%" Height="260px"
                      ChartOptions="@(new ChartOptions { ChartPalette = _permitColors })" />
        </div>
    </MudItem>
</MudGrid>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="12" md="7">
        <div class="chart-card chart-card-action" role="button" tabindex="0"
             @onclick='() => GoTo("/reports")' @onkeydown='e => OnCardKeyDown(e, "/reports")'>
            <div class="chart-header">
                <h4>Xu hướng hết hạn tạm trú (12 tháng)</h4>
            </div>
            <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@_trendSeries"
                      XAxisLabels="@_trendLabels" Width="100%" Height="260px"
                      ChartOptions="@(new ChartOptions { ChartPalette = new[] { "#d97706", "#059669" } })" />
        </div>
    </MudItem>
    <MudItem xs="12" md="5">
        <div class="chart-card chart-card-action" role="button" tabindex="0"
             @onclick='() => GoTo("/employees")' @onkeydown='e => OnCardKeyDown(e, "/employees")'>
            <div class="chart-header">
                <h4>⚠ Cảnh báo - Sắp hết hạn</h4>
                <MudLink Href="/employees" Typo="Typo.caption" Style="font-weight: 600;">Xem tất cả →</MudLink>
            </div>
            <div class="alert-list">
                @foreach (var emp in _expiringEmployees.Take(5))
                {
                    var days = emp.DaysUntilExpiry ?? 999;
                    var css = days <= 7 ? "danger" : days <= 30 ? "warning" : "info";
                    <div class="alert-item @css">
                        <div class="alert-info">
                            <strong>@emp.StaffName</strong>
                            <span>@emp.Company?.CompanyName</span>
                        </div>
                        <span class="alert-badge @css">@days ngày</span>
                    </div>
                }
                @if (!_expiringEmployees.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="pa-4">
                        Không có cảnh báo nào
                    </MudText>
                }
            </div>
        </div>
    </MudItem>
</MudGrid>

@code {
    private bool _loading = true;
    private string? _error;
    private string _chartYear = "2026";

    private int _totalCompanies;
    private int _totalEmployees;
    private int _expiringCount;
    private int _withPermit;
    private int _familyVisitCount;
    private int _familyVisitExpiringCount;
    private int _newCompaniesThisMonth = 3;
    private int _newEmployeesThisMonth = 8;

    private string[] _nationalityLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _nationalitySeries = new();
    private double[] _permitData = Array.Empty<double>();
    private string[] _permitLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _trendSeries = new();
    private string[] _trendLabels = Array.Empty<string>();
    private List<IRM.Data.Models.Employee> _expiringEmployees = new();

    private readonly string[] _barColors = { "#2563eb", "#7c3aed", "#dc2626", "#d97706", "#059669", "#0d9488", "#6366f1", "#14b8a6", "#a3a3a3" };
    private readonly string[] _permitColors = { "#059669", "#2563eb", "#d97706", "#94a3b8" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await DashboardSvc.GetDashboardAsync();
            _totalCompanies = data.TotalCompanies;
            _totalEmployees = data.TotalEmployees;
            _expiringCount = data.ExpiringCount;
            _withPermit = data.WithWorkPermit;
            _familyVisitCount = data.FamilyVisitCount;
            _familyVisitExpiringCount = data.FamilyVisitExpiringCount;
            _expiringEmployees = data.ExpiringEmployees;

            if (data.NationalityStats.Any())
            {
                _nationalityLabels = data.NationalityStats.Select(x => x.Label).ToArray();
                _nationalitySeries = new()
                {
                    new ChartSeries<double>
                    {
                        Name = "Số LĐ",
                        Data = data.NationalityStats.Select(x => (double)x.Value).ToArray()
                    }
                };
            }

            if (data.WorkPermitStats.Any())
            {
                _permitLabels = data.WorkPermitStats.Select(x => x.Label).ToArray();
                _permitData = data.WorkPermitStats.Select(x => (double)x.Value).ToArray();
            }

            GenerateTrendData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _totalCompanies = 0;
            _totalEmployees = 0;
            _expiringCount = 0;
            _withPermit = 0;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_loading)
        {
            await AnimateKPIs();
        }
    }

    private async Task AnimateKPIs()
    {
        try
        {
            await JS.InvokeVoidAsync("irmInterop.animateNumber", "kpiCompanies", _totalCompanies, 1200);
            await JS.InvokeVoidAsync("irmInterop.animateNumber", "kpiEmployees", _totalEmployees, 1500);
            await JS.InvokeVoidAsync("irmInterop.animateNumber", "kpiExpiring", _expiringCount, 800);
            await JS.InvokeVoidAsync("irmInterop.animateNumber", "kpiPermit", _withPermit, 1300);
        }
        catch { /* JS interop may fail during prerender */ }
    }

    private void GoTo(string href)
    {
        Nav.NavigateTo(href);
    }

    private void OnCardKeyDown(KeyboardEventArgs e, string href)
    {
        if (e.Key is "Enter" or " ")
        {
            GoTo(href);
        }
    }

    private void GenerateTrendData()
    {
        var now = DateTime.Now;
        _trendLabels = Enumerable.Range(-11, 12)
            .Select(i => now.AddMonths(i).ToString("MM/yy"))
            .ToArray();

        var rng = new Random(42);
        _trendSeries = new()
        {
            new ChartSeries<double>
            {
                Name = "Hết hạn tạm trú",
                Data = Enumerable.Range(0, 12).Select(_ => (double)rng.Next(20, 45)).ToArray()
            },
            new ChartSeries<double>
            {
                Name = "Đã gia hạn",
                Data = Enumerable.Range(0, 12).Select(_ => (double)rng.Next(15, 38)).ToArray()
            }
        };
    }
}
