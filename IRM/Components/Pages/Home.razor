@page "/"

@using IRM.Services
@inject DashboardService DashboardSvc

<PageTitle>Dashboard — IRM v2.0</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Chưa kết nối được database: @_error — Hiển thị dữ liệu mẫu.
    </MudAlert>
}

@* ── KPI Cards — Compact ── *@
<MudGrid Spacing="3" Class="mb-3">
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border-left: 4px solid var(--mud-palette-primary); border: 1px solid var(--mud-palette-divider); border-left: 4px solid var(--mud-palette-primary);">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">Tổng công ty</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 800;">@_totalCompanies.ToString("N0")</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" />
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border: 1px solid var(--mud-palette-divider); border-left: 4px solid var(--mud-palette-success);">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">Tổng LĐ nước ngoài</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 800;">@_totalEmployees.ToString("N0")</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Success" />
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border: 1px solid var(--mud-palette-divider); border-left: 4px solid var(--mud-palette-warning);">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">Sắp hết hạn tạm trú</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Warning" Style="font-weight: 800;">@_expiringCount</MudText>
                </MudStack>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">⚠ 30 ngày</MudChip>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border: 1px solid var(--mud-palette-divider); border-left: 4px solid var(--mud-palette-tertiary);">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;">Đã có GPLĐ</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight: 800; color: var(--mud-palette-tertiary);">@_withPermit.ToString("N0")</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Verified" Style="color: var(--mud-palette-tertiary);" />
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@* ── Main row: Bar Chart + Donut + Alerts ── *@
<MudGrid Spacing="3" Class="mb-3">
    <MudItem xs="12" md="5">
        <MudPaper Elevation="0" Class="pa-3 rounded-lg border-solid border" Style="border-width: 1px; height: 100%;">
            <MudText Typo="Typo.subtitle2" Style="font-weight: 700;" Class="mb-2">LĐ nước ngoài theo quốc tịch</MudText>
            <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_nationalitySeries"
                      XAxisLabels="@_nationalityLabels" Width="100%" Height="220px" />
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Elevation="0" Class="pa-3 rounded-lg border-solid border" Style="border-width: 1px; height: 100%;">
            <MudText Typo="Typo.subtitle2" Style="font-weight: 700;" Class="mb-2">Tỷ lệ GPLĐ</MudText>
            <MudChart T="double" ChartType="ChartType.Donut" InputData="@_permitData"
                      InputLabels="@_permitLabels" Width="100%" Height="220px"
                      ChartOptions="@(new ChartOptions { ChartPalette = _permitColors })" />
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Class="pa-3 rounded-lg border-solid border" Style="border-width: 1px; height: 100%;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudText Typo="Typo.subtitle2" Style="font-weight: 700;">⚠️ Cảnh báo — Sắp hết hạn</MudText>
                <MudLink Href="/employees" Typo="Typo.caption" Style="font-weight: 600;">Tất cả →</MudLink>
            </MudStack>
            @foreach (var emp in _expiringEmployees.Take(6))
            {
                var days = emp.DaysUntilExpiry ?? 999;
                var bgColor = days <= 7 ? "var(--mud-palette-error-hover)" : days <= 30 ? "var(--mud-palette-warning-hover)" : "var(--mud-palette-info-hover)";
                var borderColor = days <= 7 ? "var(--mud-palette-error)" : days <= 30 ? "var(--mud-palette-warning)" : "var(--mud-palette-info)";
                var severity = days <= 7 ? Color.Error : days <= 30 ? Color.Warning : Color.Info;

                <MudPaper Elevation="0" Class="pa-2 mb-1 rounded d-flex align-center justify-space-between"
                          Style="@($"background: {bgColor}; border: 1px solid {borderColor};")">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2" Style="font-weight: 600; font-size: 0.8rem;">@emp.StaffName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.7rem;">@emp.Company?.CompanyName</MudText>
                    </MudStack>
                    <MudChip T="string" Size="Size.Small" Color="@severity" Variant="Variant.Filled"
                             Style="font-weight: 700; font-size: 0.7rem;">@days ngày</MudChip>
                </MudPaper>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private bool _loading = true;
    private string? _error;

    private int _totalCompanies, _totalEmployees, _expiringCount, _withPermit;
    private string[] _nationalityLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _nationalitySeries = new();
    private double[] _permitData = Array.Empty<double>();
    private string[] _permitLabels = Array.Empty<string>();
    private string[] _permitColors = { "#059669", "#2563eb", "#d97706", "#94a3b8" };
    private List<IRM.Data.Models.Employee> _expiringEmployees = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await DashboardSvc.GetDashboardAsync();

            _totalCompanies = data.TotalCompanies;
            _totalEmployees = data.TotalEmployees;
            _expiringCount = data.ExpiringCount;
            _withPermit = data.WithWorkPermit;
            _expiringEmployees = data.ExpiringEmployees;

            // Nationality chart
            if (data.NationalityStats.Any())
            {
                _nationalityLabels = data.NationalityStats.Select(x => x.Label).ToArray();
                _nationalitySeries = new() { new ChartSeries<double> { Name = "Số LĐ", Data = data.NationalityStats.Select(x => (double)x.Value).ToArray() } };
            }

            // Work permit chart
            if (data.WorkPermitStats.Any())
            {
                _permitLabels = data.WorkPermitStats.Select(x => x.Label).ToArray();
                _permitData = data.WorkPermitStats.Select(x => (double)x.Value).ToArray();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            // Fallback data
            _totalCompanies = 0; _totalEmployees = 0; _expiringCount = 0; _withPermit = 0;
        }
        finally
        {
            _loading = false;
        }
    }
}
