@page "/search"

@using Microsoft.AspNetCore.Components.Web
@using IRM.Services
@using IRM.Data.Models
@inject SearchService SearchSvc

<PageTitle>Tìm kiếm — IRM v2.0</PageTitle>

<MudStack AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 800;">Tìm kiếm toàn cục</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">Nhập tên, hộ chiếu, công ty, quốc tịch... — tìm trên mọi trường dữ liệu</MudText>
</MudStack>

<MudStack Row="true" Justify="Justify.Center" Class="mb-4">
    <MudTextField T="string" @bind-Value="_searchQuery" Placeholder="Nhập từ khóa tìm kiếm..."
                  Variant="Variant.Outlined" Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Style="max-width: 600px;" Immediate="true"
                  OnKeyUp="OnSearchKeyUp" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               OnClick="DoSearchAsync" Disabled="@_loading">
        @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" /> }
        else { <text>Tìm kiếm</text> }
    </MudButton>
</MudStack>

@if (_hasSearched && _result != null)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3" Align="Align.Center">
        Tìm thấy <strong>@_result.TotalCount</strong> kết quả cho "<em>@_result.Keyword</em>"
    </MudText>

    <MudGrid Spacing="2" Class="mb-4" Justify="Justify.Center">
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="0" Class="pa-2 text-center rounded-lg border-solid border" Style="border-width:1px;">
                <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight:800;">@_result.Employees.Count</MudText>
                <MudText Typo="Typo.caption">Nhân viên</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="0" Class="pa-2 text-center rounded-lg border-solid border" Style="border-width:1px;">
                <MudText Typo="Typo.h6" Color="Color.Secondary" Style="font-weight:800;">@_result.Companies.Count</MudText>
                <MudText Typo="Typo.caption">Công ty</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Employee results ── *@
    @foreach (var emp in _result.Employees)
    {
        <MudPaper Elevation="0" Class="pa-3 mb-2 rounded-lg border-solid border d-flex align-center" Style="border-width: 1px;">
            <MudText Style="font-size: 1.5rem; margin-right: 12px;">👥</MudText>
            <MudStack Spacing="0" Style="flex: 1;">
                <MudText Typo="Typo.body1" Style="font-weight: 700;">@emp.StaffName — @(emp.NationalityNav?.NationalityName ?? emp.Nationality)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    HC: @emp.Passport · @emp.Company?.CompanyName · @(emp.Career?.CareerName ?? "") · @emp.WorkPermitString · Hạn TT: @(emp.TemporaryStay?.ToString("dd/MM/yyyy") ?? "—")
                </MudText>
            </MudStack>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary">Xem →</MudButton>
        </MudPaper>
    }

    @* ── Company results ── *@
    @foreach (var c in _result.Companies)
    {
        <MudPaper Elevation="0" Class="pa-3 mb-2 rounded-lg border-solid border d-flex align-center" Style="border-width: 1px;">
            <MudText Style="font-size: 1.5rem; margin-right: 12px;">🏢</MudText>
            <MudStack Spacing="0" Style="flex: 1;">
                <MudText Typo="Typo.body1" Style="font-weight: 700;">@c.CompanyName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @(c.Field?.FieldName ?? "") · @c.TotalAmount NLĐ · @c.Address
                </MudText>
            </MudStack>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary">Xem →</MudButton>
        </MudPaper>
    }
}

@code {
    private string _searchQuery = "";
    private bool _hasSearched;
    private bool _loading;
    private SearchResult? _result;

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoSearchAsync();
    }

    private async Task DoSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;
        _loading = true;
        try
        {
            _result = await SearchSvc.SearchAsync(_searchQuery);
            _hasSearched = true;
        }
        catch { _result = new SearchResult(); }
        finally { _loading = false; }
    }
}
