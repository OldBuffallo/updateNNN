@page "/companies"

@using Microsoft.AspNetCore.Components.Web
@using IRM.Services
@using IRM.Data.Models
@inject CompanyService CompanySvc
@inject CatalogService CatalogSvc

<PageTitle>Quản lý Công ty — IRM v2.0</PageTitle>

@* ── Header ── *@
<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight: 800;">🏢 Danh sách Công ty</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">Tổng: @_companies.Count công ty đang hoạt động</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.UploadFile"
                   Color="Color.Default" Href="/import">Import Excel</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary">Thêm công ty</MudButton>
    </MudStack>
</MudStack>

@* ── Filters ── *@
<MudStack Row="true" Spacing="2" Class="mb-3">
    <MudTextField T="string" @bind-Value="_searchText" Placeholder="Tìm theo tên, địa chỉ..."
                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Style="max-width: 350px;" OnKeyUp="OnSearchKeyUp" />
    <MudSelect T="int?" @bind-Value="_selectedFieldId" Placeholder="Lĩnh vực"
               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
               Style="max-width: 200px;">
        @foreach (var f in _fields)
        {
            <MudSelectItem T="int?" Value="@((int?)f.IDField)">@f.FieldName</MudSelectItem>
        }
    </MudSelect>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadDataAsync" Size="Size.Small">Lọc</MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}

@* ── DataGrid ── *@
<MudDataGrid Items="@_companies" T="Company" Filterable="false" Sortable="true"
             Dense="true" Hover="true" Bordered="false" Striped="true"
             RowsPerPage="15" Class="rounded-lg border-solid border" Style="border-width: 1px;">
    <Columns>
        <TemplateColumn Title="STT" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudText Typo="Typo.body2">@(_companies.IndexOf(context.Item) + 1)</MudText>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.CompanyName" Title="Tên công ty" Style="font-weight: 600;" />
        <PropertyColumn Property="x => x.TypeOfBusiniess" Title="Loại hình" />
        <TemplateColumn Title="Lĩnh vực">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">@(context.Item.Field?.FieldName ?? "")</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.TotalAmount" Title="Tổng LĐ" Style="font-weight: 700;" />
        <TemplateColumn Title="Có GPLĐ">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">@context.Item.QuantityAvailable</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Chưa có">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">@context.Item.QuantityNotYet</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Miễn">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@context.Item.AmountOfExemption</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Cán bộ TD">
            <CellTemplate>
                <MudText Typo="Typo.body2">@(context.Item.Tracker?.Name)</MudText>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Thao tác" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="Company" />
    </PagerContent>
</MudDataGrid>

@code {
    private List<Company> _companies = new();
    private List<Field> _fields = new();
    private string? _searchText;
    private int? _selectedFieldId;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _fields = await CatalogSvc.GetFieldsAsync();
            await LoadDataAsync();
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _companies = await CompanySvc.GetAllAsync(_searchText, _selectedFieldId);
        }
        catch { _companies = new(); }
        finally { _loading = false; }
    }
}
