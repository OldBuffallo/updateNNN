@page "/companies"
@rendermode InteractiveServer

<PageTitle>Quản lý Công ty — IRM v2.0</PageTitle>

@* ── Header ── *@
<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight: 800;">🏢 Danh sách Công ty</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">Tổng: @_companies.Count công ty đang hoạt động</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.UploadFile"
                   Color="Color.Default" Href="/import">Import Excel</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary">Thêm công ty</MudButton>
    </MudStack>
</MudStack>

@* ── DataGrid ── *@
<MudDataGrid Items="@_companies" T="Company" Filterable="true" Sortable="true"
             Dense="true" Hover="true" Bordered="false" Striped="true"
             RowsPerPage="10" Class="rounded-lg border-solid border" Style="border-width: 1px;">
    <Columns>
        <PropertyColumn Property="x => x.Id" Title="STT" Sortable="false" Filterable="false" />
        <PropertyColumn Property="x => x.Name" Title="Tên công ty" Style="font-weight: 600;" />
        <PropertyColumn Property="x => x.Type" Title="Loại hình" />
        <TemplateColumn Title="Lĩnh vực">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">@context.Item.Field</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.TotalWorkers" Title="Tổng LĐ" Style="font-weight: 700;" />
        <TemplateColumn Title="Có GPLĐ">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">@context.Item.WithPermit</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Chưa có">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">@context.Item.WithoutPermit</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Miễn">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@context.Item.Exempt</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.Tracker" Title="Cán bộ TD" />
        <TemplateColumn Title="Thao tác" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
                <MudIconButton Icon="@Icons.Material.Filled.UploadFile" Size="Size.Small" Color="Color.Default" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="Company" />
    </PagerContent>
</MudDataGrid>

@code {
