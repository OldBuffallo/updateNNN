@page "/import"
@using IRM.Services
@using IRM.Data.Models
@inject ImportService ImportSvc
@inject CompanyService CompanySvc
@inject ExportService ExportSvc
@inject EmployeeService EmployeeSvc
@inject CatalogService CatalogSvc
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Import Excel — IRM v2.0</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight: 800;">📤 Import dữ liệu từ Excel</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Cập nhật danh sách lao động — Mỗi phiên import đều có lịch sử để hoàn tác</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History"
                   Color="Color.Default" OnClick="@(() => _showHistory = !_showHistory)">
            @(_showHistory ? "Ẩn lịch sử" : "Lịch sử Import")
        </MudButton>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download"
                   Color="Color.Primary" OnClick="DownloadSampleFile">
            📥 Tải file mẫu
        </MudButton>
        <MudButton Variant="@(_manualMode ? Variant.Filled : Variant.Outlined)"
                   StartIcon="@Icons.Material.Filled.Edit"
                   Color="Color.Success" OnClick="@(() => _manualMode = !_manualMode)">
            @(_manualMode ? "📤 Chuyển Import Excel" : "✏️ Nhập thủ công")
        </MudButton>
    </MudStack>
</MudStack>

@* ── Import History Panel ── *@
@if (_showHistory)
{
    <MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg border-solid border" Style="border-width: 1px;">
        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-3">📋 Lịch sử phiên Import</MudText>
        @if (_importHistory.Any())
        {
            <MudSimpleTable Dense="true" Hover="true">
                <thead>
                    <tr>
                        <th>Mã phiên</th><th>Thời gian</th><th>File</th><th>Công ty</th>
                        <th>Thêm</th><th>Cập nhật</th><th>Lỗi</th><th>Trạng thái</th><th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _importHistory)
                    {
                        <tr>
                            <td><MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 11px;">@s.SessionId</MudText></td>
                            <td>@s.Time</td>
                            <td Style="font-weight: 600;">@s.FileName</td>
                            <td>@s.Company</td>
                            <td><MudText Color="Color.Success" Style="font-weight: 700;">+@s.Added</MudText></td>
                            <td><MudText Color="Color.Warning" Style="font-weight: 700;">@s.Updated</MudText></td>
                            <td><MudText Color="Color.Error" Style="font-weight: 700;">@s.Errors</MudText></td>
                            <td>
                                @{
                                    var (statusLabel, statusColor) = s.Status switch
                                    {
                                        "committed" => ("✅ Đã lưu", Color.Success),
                                        "rolledback" => ("↩ Đã hoàn tác", Color.Secondary),
                                        _ => ("📝 Nháp", Color.Info)
                                    };
                                }
                                <MudChip T="string" Size="Size.Small" Color="@statusColor" Variant="Variant.Filled">@statusLabel</MudChip>
                            </td>
                            <td>
                                <MudStack Row="true" Spacing="1">
                                    @if (s.Status == "committed")
                                    {
                                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error"
                                                   StartIcon="@Icons.Material.Filled.Undo"
                                                   OnClick="@(() => RollbackSession(s.SessionId))">Hoàn tác</MudButton>
                                    }
                                </MudStack>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Chưa có phiên import nào.</MudText>
        }
    </MudPaper>
}

@* ── MANUAL ENTRY FORM ── *@
@if (_manualMode)
{
    <MudPaper Elevation="0" Class="pa-6 mb-4 rounded-xl border-solid border" Style="border-width: 1px;">
        <MudText Typo="Typo.h6" Style="font-weight: 800;" Class="mb-1">✏️ Nhập thủ công — Thêm nhân viên trực tiếp</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Điền thông tin bên dưới để thêm nhân viên mà không cần file Excel</MudText>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="6"><MudTextField T="string" Label="Họ tên *" @bind-Value="_mf.StaffName" Variant="Variant.Outlined" Required="true" HelperText="Bắt buộc — Nhập đầy đủ họ và tên" /></MudItem>
            <MudItem xs="6" md="3"><MudSelect T="int" Label="Giới tính" @bind-Value="_mf.Gender" Variant="Variant.Outlined"><MudSelectItem Value="1">Nam</MudSelectItem><MudSelectItem Value="0">Nữ</MudSelectItem></MudSelect></MudItem>
            <MudItem xs="6" md="3"><MudDatePicker Label="Ngày sinh" @bind-Date="_mf.Birthday" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" /></MudItem>

            <MudItem xs="6" md="4"><MudSelect T="string" Label="Quốc tịch" @bind-Value="_mf.Nationality" Variant="Variant.Outlined" Clearable="true">@foreach(var n in _mfNationalities){<MudSelectItem Value="@n.NationalityCode">@n.NationalityName</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="6" md="4"><MudTextField T="string" Label="Số hộ chiếu *" @bind-Value="_mf.Passport" Variant="Variant.Outlined" HelperText="Quan trọng — Dùng để kiểm tra trùng lặp" /></MudItem>
            <MudItem xs="12" md="4"><MudAutocomplete T="Company" Label="Công ty *" Value="_mfCompany" ValueChanged="v => { _mfCompany = v; _mf.IDCompany = v?.IDCompany ?? 0; }" SearchFunc="SearchCompanyAsync" ToStringFunc="@(c => c?.CompanyName ?? "")" Variant="Variant.Outlined" ResetValueOnEmptyText="true" /></MudItem>

            <MudItem xs="6" md="4"><MudSelect T="int?" Label="Nghề nghiệp" @bind-Value="_mf.IDCareer" Variant="Variant.Outlined" Clearable="true">@foreach(var c in _mfCareers){<MudSelectItem T="int?" Value="@((int?)c.IDCareer)">@c.CareerName</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="6" md="4"><MudSelect T="int" Label="GPLĐ" @bind-Value="_mf.WorkPermit" Variant="Variant.Outlined"><MudSelectItem Value="0">Miễn GPLĐ</MudSelectItem><MudSelectItem Value="1">Đã có GPLĐ</MudSelectItem><MudSelectItem Value="2">Chưa có GPLĐ</MudSelectItem><MudSelectItem Value="3">NĐT miễn GPLĐ</MudSelectItem><MudSelectItem Value="4">NĐT đã có GPLĐ</MudSelectItem><MudSelectItem Value="5">NĐT chưa có GPLĐ</MudSelectItem></MudSelect></MudItem>
            <MudItem xs="6" md="4"><MudDatePicker Label="Hạn tạm trú" @bind-Date="_mf.TemporaryStay" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" HelperText="Quan trọng — Cảnh báo hết hạn" /></MudItem>

            <MudItem xs="6" md="4"><MudTextField T="string" Label="Số GPLĐ" @bind-Value="_mf.WorkPermitNumber" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="6" md="4"><MudTextField T="string" Label="Số Visa" @bind-Value="_mf.VisaNumber" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField T="string" Label="Địa chỉ" @bind-Value="_mf.Address" Variant="Variant.Outlined" /></MudItem>

            <MudItem xs="12"><MudTextField T="string" Label="Ghi chú" @bind-Value="_mf.Note" Variant="Variant.Outlined" Lines="2" /></MudItem>

            @* Thăm thân *@
            <MudItem xs="12"><MudDivider Class="my-1" /><MudText Typo="Typo.subtitle2" Style="font-weight:700;">👨‍👩‍👧 Thông tin thăm thân (tùy chọn)</MudText></MudItem>
            <MudItem xs="6" md="3"><MudSelect T="int" Label="Thăm thân" @bind-Value="_mf.FamilyVisit" Variant="Variant.Outlined"><MudSelectItem Value="0">Không</MudSelectItem><MudSelectItem Value="1">Có</MudSelectItem></MudSelect></MudItem>
            @if (_mf.FamilyVisit == 1)
            {
                <MudItem xs="6" md="3"><MudTextField T="string" Label="Tên người thân" @bind-Value="_mf.FamilyVisitRelativeName" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="6" md="3"><MudSelect T="string" Label="Quan hệ" @bind-Value="_mf.FamilyVisitRelationship" Variant="Variant.Outlined"><MudSelectItem Value="@("Vợ/Chồng")">Vợ/Chồng</MudSelectItem><MudSelectItem Value="@("Con")">Con</MudSelectItem><MudSelectItem Value="@("Cha/Mẹ")">Cha/Mẹ</MudSelectItem><MudSelectItem Value="@("Anh/Chị/Em")">Anh/Chị/Em</MudSelectItem></MudSelect></MudItem>
                <MudItem xs="6" md="3"><MudTextField T="string" Label="CMND/CCCD người thân" @bind-Value="_mf.FamilyVisitRelativeIdCard" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="6" md="3"><MudDatePicker Label="Ngày bắt đầu TT" @bind-Date="_mf.FamilyVisitStartDate" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" /></MudItem>
                <MudItem xs="6" md="3"><MudDatePicker Label="Hạn thăm thân" @bind-Date="_mf.FamilyVisitEndDate" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" /></MudItem>
            }
        </MudGrid>

        <MudStack Row="true" Justify="Justify.Center" Spacing="3" Class="mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="ResetManualForm" StartIcon="@Icons.Material.Filled.Clear">Xóa form</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="SaveManualEntryAsync"
                       Disabled="@(string.IsNullOrWhiteSpace(_mf.StaffName) || _mf.IDCompany == 0)">
                ➕ Thêm nhân viên
            </MudButton>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_mf.StaffName) && _mf.IDCompany == 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">⚠️ Vui lòng chọn <strong>Công ty</strong> trước khi thêm nhân viên.</MudAlert>
        }
        @if (!string.IsNullOrWhiteSpace(_mf.StaffName) && string.IsNullOrWhiteSpace(_mf.Passport))
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">💡 Nên điền <strong>Số hộ chiếu</strong> để hệ thống kiểm tra trùng lặp.</MudAlert>
        }
    </MudPaper>
}

@* ── Wizard Steps (Excel Import Mode) ── *@
@if (!_manualMode)
{
<MudPaper Elevation="0" Class="pa-3 mb-4 rounded-lg border-solid border" Style="border-width: 1px;">
    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="0">
        @for (int i = 1; i <= 4; i++)
        {
            var step = i;
            var labels = new[] { "Upload file", "Ghép cột", "Xem trước", "Kết quả" };
            <MudStack AlignItems="AlignItems.Center" Spacing="1">
                <MudAvatar Size="Size.Medium"
                           Color="@(step < _currentStep ? Color.Success : step == _currentStep ? Color.Primary : Color.Default)"
                           Variant="@(step <= _currentStep ? Variant.Filled : Variant.Outlined)">
                    @(step < _currentStep ? "✓" : step.ToString())
                </MudAvatar>
                <MudText Typo="Typo.caption" Style="@($"font-weight: {(step == _currentStep ? "700" : "500")}; color: {(step == _currentStep ? "var(--mud-palette-primary)" : "inherit")};")">
                    @labels[step - 1]
                </MudText>
            </MudStack>
            @if (i < 4)
            {
                <MudDivider Style="@($"width: 60px; margin: 0 8px; border-color: {(step < _currentStep ? "var(--mud-palette-success)" : "var(--mud-palette-divider)")};")"/>
            }
        }
    </MudStack>
</MudPaper>

<MudContainer MaxWidth="MaxWidth.Medium">
    @* Step 1: Upload *@
    @if (_currentStep == 1)
    {
        <MudPaper Elevation="0" Class="pa-8 rounded-xl border-dashed border-2 text-center"
                  Style="border-color: var(--mud-palette-primary);">
            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large"
                     Style="font-size: 3rem; opacity: 0.4;" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="mt-3" Style="font-weight: 700;">Kéo thả file Excel vào đây</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                hoặc nhấn nút bên dưới để chọn file
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2">.xlsx hoặc .xls — Hệ thống hỗ trợ cả hai định dạng Excel</MudText>

            <MudStack AlignItems="AlignItems.Center" Class="mt-4">
                <InputFile OnChange="HandleFileUpload" accept=".xlsx,.xls" id="fileInput" style="display:none" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" HtmlTag="label" For="fileInput"
                           StartIcon="@Icons.Material.Filled.AttachFile">
                    Chọn file Excel
                </MudButton>
            </MudStack>

            @if (!string.IsNullOrEmpty(_uploadedFileName))
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mt-3">
                    📄 Đã chọn: <strong>@_uploadedFileName</strong> — @_sheetInfo
                </MudAlert>
            }
        </MudPaper>

        <MudGrid Spacing="3" Class="mt-3">
            <MudItem xs="6">
                <MudAutocomplete T="Company" @bind-Value="_selectedCompany" Label="Chọn công ty (tùy chọn)"
                                 SearchFunc="SearchCompanyAsync" ToStringFunc="@(c => c?.CompanyName ?? "")"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                 ResetValueOnEmptyText="true" Immediate="true" />
            </MudItem>
            <MudItem xs="6">
                <MudSelect T="int?" Label="Template ghép cột" Variant="Variant.Outlined" @bind-Value="_selectedTemplateId"
                           Margin="Margin.Dense" Dense="true">
                    <MudSelectItem T="int?" Value="@((int?)null)">— Không dùng template —</MudSelectItem>
                    @foreach (var t in _templates)
                    {
                        <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.TemplateName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
            💡 <strong>An toàn dữ liệu:</strong> Mỗi lần import tạo phiên riêng. Bạn có thể <strong>hoàn tác</strong> bất cứ lúc nào từ Lịch sử Import.
        </MudAlert>

        <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       Disabled="@(_fileStream == null)"
                       OnClick="GoToStep2">Tiếp tục</MudButton>
        </MudStack>
    }

    @* Step 2: Column Mapping *@
    @if (_currentStep == 2)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3">
            📄 <strong>@_uploadedFileName</strong> — @_sheetInfo
        </MudAlert>

        <MudSimpleTable Dense="true" Hover="true" Class="rounded-lg border-solid border mb-3" Style="border-width: 1px;">
            <thead><tr><th>Cột Excel</th><th></th><th>Trường hệ thống</th><th>Trạng thái</th></tr></thead>
            <tbody>
                @foreach (var m in _columnMappings)
                {
                    <tr style="@(m.SystemField == "skip" ? "background: var(--mud-palette-warning-hover);" : "")">
                        <td><strong>Cột @((char)('A' + m.ExcelColumnIndex)): "@m.ExcelColumnName"</strong></td>
                        <td>→</td>
                        <td>
                            <MudSelect T="string" Value="@m.SystemField" Variant="Variant.Outlined"
                                       Dense="true" Margin="Margin.Dense"
                                       ValueChanged="@(val => OnMappingChanged(m, val))">
                                @foreach (var (key, label) in SystemFields.All)
                                {
                                    <MudSelectItem Value="@key">@label</MudSelectItem>
                                }
                            </MudSelect>
                        </td>
                        <td>
                            @if (m.SystemField == "skip")
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">⚠️ Bỏ qua</MudChip>
                            }
                            else if (m.IsAutoMapped)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">✏️ Thủ công</MudChip>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        

        <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
            ✅ @(_columnMappings.Count(m => m.SystemField != "skip"))/@_columnMappings.Count cột đã ghép ·
            <MudCheckBox T="bool" @bind-Value="_saveTemplate" Dense="true" Label="Lưu template" Class="d-inline" />
        </MudAlert>

        @if (_saveTemplate)
        {
            <MudTextField @bind-Value="_templateName" Label="Tên template" Variant="Variant.Outlined"
                          Dense="true" Margin="Margin.Dense" Class="mb-3"
                          Placeholder="VD: Template Samsung" />
        }

        <MudStack Row="true" Justify="Justify.Center" Spacing="3">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => _currentStep = 1)" StartIcon="@Icons.Material.Filled.ArrowBack">Quay lại</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       OnClick="GoToStep3" EndIcon="@Icons.Material.Filled.ArrowForward"
                       Disabled="@_isProcessing">
                @if (_isProcessing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Tiếp tục
            </MudButton>
        </MudStack>
    }

    @* Step 3: Preview *@
    @if (_currentStep == 3)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3">
            👁️ Tổng: @_previewRows.Count dòng · 🟢 @(_previewRows.Count(r => r.Status == "new")) mới · 🟡 @(_previewRows.Count(r => r.Status == "duplicate")) trùng · 🔴 @(_previewRows.Count(r => r.Status == "error")) lỗi
        </MudAlert>

        <MudSimpleTable Dense="true" Hover="true" Class="rounded-lg border-solid border mb-3" Style="border-width: 1px; max-height: 400px; overflow-y: auto;">
            <thead><tr><th>Dòng</th><th>TT</th><th>Họ tên</th><th>Quốc tịch</th><th>Hộ chiếu</th><th>Nghề nghiệp</th><th>GPLĐ</th><th>Xử lý</th></tr></thead>
            <tbody>
                @foreach (var row in _previewRows)
                {
                    var rowBg = row.Status switch
                    {
                        "duplicate" => "background: var(--mud-palette-warning-hover);",
                        "error" => "background: var(--mud-palette-error-hover);",
                        _ => ""
                    };
                    var chipColor = row.Status switch
                    {
                        "new" => Color.Success,
                        "duplicate" => Color.Warning,
                        _ => Color.Error
                    };
                    var chipLabel = row.Status switch
                    {
                        "new" => "Mới",
                        "duplicate" => "Trùng",
                        _ => "Lỗi"
                    };
                    <tr style="@rowBg">
                        <td>@row.RowNumber</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@chipColor">@chipLabel</MudChip></td>
                        <td>@row.StaffName</td>
                        <td>@row.NationalityDisplay</td>
                        <td><code>@row.Passport</code></td>
                        <td>@row.CareerDisplay</td>
                        <td>@row.WorkPermitDisplay</td>
                        <td>
                            @if (row.Status == "duplicate" && row.ExistingEmployeeId.HasValue)
                            {
                                <MudSelect T="string" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                           Value="@GetDuplicateDecision(row.ExistingEmployeeId.Value)"
                                           ValueChanged="@(val => SetDuplicateDecision(row.ExistingEmployeeId.Value, val))"
                                           Style="min-width: 120px;">
                                    <MudSelectItem Value="@("update")">🔄 Cập nhật</MudSelectItem>
                                    <MudSelectItem Value="@("skip")">⏭️ Bỏ qua</MudSelectItem>
                                </MudSelect>
                            }
                            else if (row.Status == "error")
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error">@row.ErrorMessage</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Success">Sẽ thêm mới</MudText>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            🔒 <strong>Dữ liệu cũ sẽ được backup.</strong> Bạn có thể hoàn tác import bất cứ lúc nào từ lịch sử.
        </MudAlert>

        <MudStack Row="true" Justify="Justify.Center" Spacing="3">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => _currentStep = 2)" StartIcon="@Icons.Material.Filled.ArrowBack">Quay lại</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       OnClick="ExecuteImport" StartIcon="@Icons.Material.Filled.FlashOn"
                       Disabled="@_isProcessing">
                @if (_isProcessing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Bắt đầu Import
            </MudButton>
        </MudStack>
    }

    @* Step 4: Result *@
    @if (_currentStep == 4 && _importResult != null)
    {
        <MudPaper Elevation="0" Class="pa-8 rounded-xl border-solid border text-center" Style="border-width: 1px;">
            <MudText Style="font-size: 3rem;">@(_importResult.Success ? "✅" : "❌")</MudText>
            <MudText Typo="Typo.h5" Color="@(_importResult.Success ? Color.Success : Color.Error)" Style="font-weight: 800;" Class="mt-2">
                @(_importResult.Success ? "Import hoàn tất!" : "Import thất bại!")
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Phiên <strong>@_importResult.SessionId</strong> · File <strong>@_uploadedFileName</strong>
            </MudText>

            <MudStack Row="true" Justify="Justify.Center" Spacing="8" Class="mt-6 mb-6">
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 800;">@_importResult.AddedCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Thêm mới</MudText>
                </MudStack>
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 800;">@_importResult.UpdatedCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Cập nhật</MudText>
                </MudStack>
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 800;">@_importResult.ErrorCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Lỗi (bỏ qua)</MudText>
                </MudStack>
                @if (_importResult.SkippedCount > 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.h3" Color="Color.Default" Style="font-weight: 800;">@_importResult.SkippedCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Bỏ qua</MudText>
                    </MudStack>
                }
            </MudStack>

            @if (_importResult.Errors.Any())
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4 text-left">
                    @foreach (var err in _importResult.Errors.Take(5))
                    {
                        <div>⚠️ @err</div>
                    }
                    @if (_importResult.Errors.Count > 5)
                    {
                        <div>... và @(_importResult.Errors.Count - 5) lỗi khác</div>
                    }
                </MudAlert>
            }

            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4 text-left">
                💾 <strong>Dữ liệu cũ đã được backup.</strong> Các bản ghi cập nhật có thể hoàn tác bất cứ lúc nào.
            </MudAlert>

            <MudStack Row="true" Justify="Justify.Center" Spacing="3">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Undo"
                           OnClick="@(() => RollbackSession(_importResult.SessionId))">↩ Hoàn tác Import này</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/employees">👥 Xem danh sách NLĐ</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetWizard"
                           StartIcon="@Icons.Material.Filled.Add">Import file khác</MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>
}

@if (_isProcessing)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999">
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="color: white; font-weight: 700;">@_processingMessage</MudText>
        </MudStack>
    </MudOverlay>
}

@code {
    // ── State ──
    private int _currentStep = 1;
    private bool _showHistory = false;
    private bool _isProcessing;
    private bool _manualMode = false;

    // Manual entry
    private Employee _mf = new() { Gender = 1 };
    private Company? _mfCompany;
    private List<NationalityEntity> _mfNationalities = new();
    private List<Career> _mfCareers = new();
    private string _processingMessage = "";

    // Step 1
    private MemoryStream? _fileStream;
    private string? _uploadedFileName;
    private string _sheetInfo = "";
    private Company? _selectedCompany;
    private int? _selectedTemplateId;
    private List<ColumnMappingTemplate> _templates = new();

    // Step 2
    private List<ColumnMapping> _columnMappings = new();
    private bool _saveTemplate;
    private string _templateName = "";

    // Step 3
    private List<ImportPreviewRow> _previewRows = new();
    private Dictionary<int, string> _duplicateDecisions = new();

    // Step 4
    private ImportResult? _importResult;

    // History
    private List<ImportSessionInfo> _importHistory = new();

    // ══════════════════════════════════════════
    // LIFECYCLE
    // ══════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
        await LoadTemplatesAsync();
        _mfNationalities = await CatalogSvc.GetNationalitiesAsync();
        _mfCareers = await CatalogSvc.GetCareersAsync();
    }

    // ══════════════════════════════════════════
    // STEP 1: UPLOAD
    // ══════════════════════════════════════════

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) &&
            !file.Name.EndsWith(".xls", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("❌ Chỉ hỗ trợ file Excel (.xlsx hoặc .xls)", Severity.Error);
            return;
        }

        _fileStream?.Dispose();
        _fileStream = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024).CopyToAsync(_fileStream); // 100MB max
        _uploadedFileName = file.Name;

        try
        {
            var (rowCount, colCount, sheetName) = ExcelReaderHelper.GetSheetInfo(_fileStream);
            _sheetInfo = $"Sheet: {sheetName} — {rowCount} dòng — {colCount} cột";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Không thể đọc file: {ex.Message}", Severity.Error);
            _fileStream = null;
            _uploadedFileName = null;
        }

        StateHasChanged();
    }

    private async Task<IEnumerable<Company>> SearchCompanyAsync(string? value, CancellationToken cancel)
    {
        return await CompanySvc.GetAllAsync(value);
    }

    // ══════════════════════════════════════════
    // STEP 2: COLUMN MAPPING
    // ══════════════════════════════════════════

    private async Task GoToStep2()
    {
        if (_fileStream == null) return;

        _isProcessing = true;
        _processingMessage = "Đang đọc cấu trúc file Excel...";
        StateHasChanged();

        try
        {
            var headers = ExcelReaderHelper.ReadHeaders(_fileStream);

            if (_selectedTemplateId.HasValue)
            {
                var template = _templates.FirstOrDefault(t => t.Id == _selectedTemplateId.Value);
                if (template != null)
                {
                    _columnMappings = ImportSvc.ApplyTemplate(template, headers);
                }
                else
                {
                    _columnMappings = ImportSvc.AutoMapColumns(headers);
                }
            }
            else
            {
                _columnMappings = ImportSvc.AutoMapColumns(headers);
            }

            _currentStep = 2;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Lỗi đọc file: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void OnMappingChanged(ColumnMapping mapping, string newValue)
    {
        mapping.SystemField = newValue;
        mapping.SystemFieldLabel = SystemFields.All.GetValueOrDefault(newValue, "");
        mapping.IsAutoMapped = false;
    }

    // ══════════════════════════════════════════
    // STEP 3: PREVIEW
    // ══════════════════════════════════════════

    private async Task GoToStep3()
    {
        if (_fileStream == null) return;

        _isProcessing = true;
        _processingMessage = "Đang phân tích dữ liệu và kiểm tra trùng lặp...";
        StateHasChanged();

        try
        {
            // Save template if checked
            if (_saveTemplate && !string.IsNullOrWhiteSpace(_templateName))
            {
                await ImportSvc.SaveTemplateAsync(_templateName, _selectedCompany.IDCompany, _columnMappings, "admin");
                await LoadTemplatesAsync();
                Snackbar.Add($"✅ Đã lưu template '{_templateName}'", Severity.Success);
            }

            _previewRows = await ImportSvc.GeneratePreviewAsync(_fileStream, _columnMappings, _selectedCompany?.IDCompany ?? 0);

            // Init duplicate decisions — default to "update"
            _duplicateDecisions = new();
            foreach (var row in _previewRows.Where(r => r.Status == "duplicate" && r.ExistingEmployeeId.HasValue))
            {
                _duplicateDecisions[row.ExistingEmployeeId!.Value] = "update";
            }

            _currentStep = 3;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Lỗi phân tích: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private string GetDuplicateDecision(int employeeId)
    {
        return _duplicateDecisions.GetValueOrDefault(employeeId, "skip");
    }

    private void SetDuplicateDecision(int employeeId, string decision)
    {
        _duplicateDecisions[employeeId] = decision;
    }

    // ══════════════════════════════════════════
    // STEP 4: EXECUTE
    // ══════════════════════════════════════════

    private async Task ExecuteImport()
    {
        if (_fileStream == null) return;

        _isProcessing = true;
        _processingMessage = "Đang import dữ liệu vào CSDL...";
        StateHasChanged();

        try
        {
            _importResult = await ImportSvc.ExecuteImportAsync(
                _previewRows,
                _duplicateDecisions,
                _selectedCompany?.IDCompany ?? 0,
                _uploadedFileName ?? "unknown.xlsx",
                "admin"
            );

            await LoadHistoryAsync();
            _currentStep = 4;

            if (_importResult.Success)
                Snackbar.Add($"✅ Import hoàn tất: +{_importResult.AddedCount} mới, ~{_importResult.UpdatedCount} cập nhật", Severity.Success);
            else
                Snackbar.Add("❌ Import thất bại!", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Import lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    // ══════════════════════════════════════════
    // ROLLBACK & HISTORY
    // ══════════════════════════════════════════

    private async Task RollbackSession(string sessionId)
    {
        _isProcessing = true;
        _processingMessage = "Đang hoàn tác import...";
        StateHasChanged();

        try
        {
            var success = await ImportSvc.RollbackImportAsync(sessionId);
            if (success)
            {
                Snackbar.Add($"✅ Đã hoàn tác phiên {sessionId} — Dữ liệu đã khôi phục.", Severity.Success);
                await LoadHistoryAsync();
            }
            else
            {
                Snackbar.Add("❌ Không thể hoàn tác phiên này.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Lỗi hoàn tác: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task LoadHistoryAsync()
    {
        try { _importHistory = await ImportSvc.GetHistoryAsync(); }
        catch { _importHistory = new(); }
    }

    private async Task LoadTemplatesAsync()
    {
        try { _templates = await ImportSvc.GetTemplatesAsync(); }
        catch { _templates = new(); }
    }

    private void ResetWizard()
    {
        _currentStep = 1;
        _fileStream?.Dispose();
        _fileStream = null;
        _uploadedFileName = null;
        _sheetInfo = "";
        _columnMappings = new();
        _previewRows = new();
        _duplicateDecisions = new();
        _importResult = null;
        _saveTemplate = false;
        _templateName = "";
    }

    // ══════════════════════════════════════════
    // MANUAL ENTRY
    // ══════════════════════════════════════════

    private async Task SaveManualEntryAsync()
    {
        if (string.IsNullOrWhiteSpace(_mf.StaffName))
        {
            Snackbar.Add("❌ Họ tên không được trống", Severity.Error);
            return;
        }
        if (_mf.IDCompany == 0)
        {
            Snackbar.Add("❌ Chưa chọn công ty", Severity.Error);
            return;
        }

        // Check duplicate passport
        if (!string.IsNullOrWhiteSpace(_mf.Passport))
        {
            var isDup = await EmployeeSvc.CheckDuplicatePassportAsync(_mf.Passport);
            if (isDup)
            {
                Snackbar.Add($"⚠️ Hộ chiếu {_mf.Passport} đã tồn tại trong hệ thống!", Severity.Warning);
                return;
            }
        }

        try
        {
            await EmployeeSvc.CreateAsync(_mf);
            Snackbar.Add($"✅ Đã thêm nhân viên \"{_mf.StaffName}\" thành công!", Severity.Success);
            ResetManualForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private void ResetManualForm()
    {
        _mf = new Employee { Gender = 1 };
        _mfCompany = null;
    }

    private async Task DownloadSampleFile()
    {
        try
        {
            var bytes = ExportSvc.GenerateSampleExcelBytes();
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("irmInterop.downloadFile",
                "Mau_Import_NLD.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                base64);
            Snackbar.Add("📥 Đã tải file mẫu — Xem sheet 'Hướng dẫn' trong file", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Lỗi tải file mẫu: {ex.Message}", Severity.Error);
        }
    }
}
