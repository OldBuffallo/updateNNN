@page "/import"
@rendermode InteractiveServer

<PageTitle>Import Excel — IRM v2.0</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight: 800;">📤 Import dữ liệu từ Excel</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Cập nhật danh sách lao động — Mỗi phiên import đều có lịch sử để hoàn tác</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History"
                   Color="Color.Default" OnClick="@(() => _showHistory = !_showHistory)">
            @(_showHistory ? "Ẩn lịch sử" : "Lịch sử Import")
        </MudButton>
    </MudStack>
</MudStack>

@* ── Import History Panel ── *@
@if (_showHistory)
{
    <MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg border-solid border" Style="border-width: 1px;">
        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-3">📋 Lịch sử phiên Import</MudText>
        <MudSimpleTable Dense="true" Hover="true">
            <thead>
                <tr>
                    <th>Mã phiên</th><th>Thời gian</th><th>File</th><th>Công ty</th>
                    <th>Thêm</th><th>Cập nhật</th><th>Lỗi</th><th>Trạng thái</th><th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _importHistory)
                {
                    <tr>
                        <td><MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 11px;">@s.Id</MudText></td>
                        <td>@s.Time</td>
                        <td Style="font-weight: 600;">@s.FileName</td>
                        <td>@s.Company</td>
                        <td><MudText Color="Color.Success" Style="font-weight: 700;">+@s.Added</MudText></td>
                        <td><MudText Color="Color.Warning" Style="font-weight: 700;">@s.Updated</MudText></td>
                        <td><MudText Color="Color.Error" Style="font-weight: 700;">@s.Errors</MudText></td>
                        <td>
                            @{
                                var (statusLabel, statusColor) = s.Status switch
                                {
                                    "committed" => ("✅ Đã lưu", Color.Success),
                                    "rolledback" => ("↩ Đã hoàn tác", Color.Secondary),
                                    _ => ("📝 Nháp", Color.Info)
                                };
                            }
                            <MudChip T="string" Size="Size.Small" Color="@statusColor" Variant="Variant.Filled">@statusLabel</MudChip>
                        </td>
                        <td>
                            <MudStack Row="true" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary" />
                                @if (s.Status == "committed")
                                {
                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.Undo"
                                               OnClick="@(() => RollbackSession(s.Id))">Hoàn tác</MudButton>
                                }
                            </MudStack>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@* ── Wizard Steps ── *@
<MudPaper Elevation="0" Class="pa-3 mb-4 rounded-lg border-solid border" Style="border-width: 1px;">
    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="0">
        @for (int i = 1; i <= 4; i++)
        {
            var step = i;
            var labels = new[] { "Upload file", "Ghép cột", "Xem trước", "Kết quả" };
            <MudStack AlignItems="AlignItems.Center" Spacing="1">
                <MudAvatar Size="Size.Medium"
                           Color="@(step < _currentStep ? Color.Success : step == _currentStep ? Color.Primary : Color.Default)"
                           Variant="@(step <= _currentStep ? Variant.Filled : Variant.Outlined)">
                    @(step < _currentStep ? "✓" : step.ToString())
                </MudAvatar>
                <MudText Typo="Typo.caption" Style="@($"font-weight: {(step == _currentStep ? "700" : "500")}; color: {(step == _currentStep ? "var(--mud-palette-primary)" : "inherit")};")">
                    @labels[step - 1]
                </MudText>
            </MudStack>
            @if (i < 4)
            {
                <MudDivider Style="@($"width: 60px; margin: 0 8px; border-color: {(step < _currentStep ? "var(--mud-palette-success)" : "var(--mud-palette-divider)")};")"/>
            }
        }
    </MudStack>
</MudPaper>

<MudContainer MaxWidth="MaxWidth.Medium">
    @* Step 1: Upload *@
    @if (_currentStep == 1)
    {
        <MudPaper Elevation="0" Class="pa-8 rounded-xl border-dashed border-2 text-center cursor-pointer"
                  Style="border-color: var(--mud-palette-primary);">
            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large"
                     Style="font-size: 3rem; opacity: 0.4;" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Class="mt-3" Style="font-weight: 700;">Kéo thả file Excel vào đây</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                hoặc <MudLink Color="Color.Primary" Style="font-weight: 600;">nhấn chọn file từ máy tính</MudLink>
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2">.xlsx, .xls, .csv — Tối đa 10MB</MudText>
        </MudPaper>

        <MudGrid Spacing="3" Class="mt-3">
            <MudItem xs="6">
                <MudSelect T="string" Label="Chọn công ty" Variant="Variant.Outlined" Value="@("Cty TNHH Samsung Electronics VN")">
                    <MudSelectItem Value="@("Cty TNHH Samsung Electronics VN")">Cty TNHH Samsung Electronics VN</MudSelectItem>
                    <MudSelectItem Value="@("Cty CP Hyundai Aluminum Vina")">Cty CP Hyundai Aluminum Vina</MudSelectItem>
                    <MudSelectItem Value="@("Cty TNHH Canon Vietnam")">Cty TNHH Canon Vietnam</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6">
                <MudSelect T="string" Label="Template ghép cột" Variant="Variant.Outlined" Value="@("none")">
                    <MudSelectItem Value="@("none")">— Không dùng template —</MudSelectItem>
                    <MudSelectItem Value="@("samsung")">Template Samsung</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
            💡 <strong>An toàn dữ liệu:</strong> Mỗi lần import tạo phiên riêng. Bạn có thể <strong>hoàn tác</strong> bất cứ lúc nào từ Lịch sử Import.
        </MudAlert>

        <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => _currentStep = 2)">Tiếp tục</MudButton>
        </MudStack>
    }

    @* Step 2: Column Mapping *@
    @if (_currentStep == 2)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3">
            📄 <strong>DanhSachNLD_Samsung_2026.xlsx</strong> — Sheet 1 — 45 dòng — 12 cột
        </MudAlert>
        <MudSimpleTable Dense="true" Hover="true" Class="rounded-lg border-solid border mb-3" Style="border-width: 1px;">
            <thead><tr><th>Cột Excel</th><th></th><th>Trường hệ thống</th><th>Trạng thái</th></tr></thead>
            <tbody>
                <tr><td><strong>Cột B: "Họ và tên"</strong></td><td>→</td><td>Họ tên (StaffName)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip></td></tr>
                <tr><td><strong>Cột C: "Giới tính"</strong></td><td>→</td><td>Giới tính (Gender)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip></td></tr>
                <tr><td><strong>Cột D: "Ngày sinh"</strong></td><td>→</td><td>Ngày sinh (Birthday)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip></td></tr>
                <tr><td><strong>Cột E: "Quốc tịch"</strong></td><td>→</td><td>Quốc tịch (Nationality)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip></td></tr>
                <tr><td><strong>Cột F: "Số hộ chiếu"</strong></td><td>→</td><td>Hộ chiếu (Passport)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip></td></tr>
                <tr style="background: var(--mud-palette-warning-hover);"><td><strong>Cột G: "Nơi cấp HC"</strong></td><td>→</td><td>— Bỏ qua —</td><td><MudChip T="string" Size="Size.Small" Color="Color.Warning">⚠️ Chưa nhận</MudChip></td></tr>
                <tr><td><strong>Cột H: "Địa chỉ"</strong></td><td>→</td><td>Địa chỉ (Address)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip></td></tr>
                <tr><td><strong>Cột I: "Chức danh"</strong></td><td>→</td><td>Nghề nghiệp (Career)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">✅ Tự động</MudChip></td></tr>
            </tbody>
        </MudSimpleTable>
        <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">✅ 11/12 cột đã tự động nhận dạng · <MudCheckBox T="bool" Value="true" Dense="true" Label="Lưu template" Class="d-inline" /></MudAlert>
        <MudStack Row="true" Justify="Justify.Center" Spacing="3">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => _currentStep = 1)" StartIcon="@Icons.Material.Filled.ArrowBack">Quay lại</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="@(() => _currentStep = 3)" EndIcon="@Icons.Material.Filled.ArrowForward">Tiếp tục</MudButton>
        </MudStack>
    }

    @* Step 3: Preview *@
    @if (_currentStep == 3)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3">
            👁️ Xem trước 5 / 45 dòng · 🟢 38 mới · 🟡 5 trùng · 🔴 2 lỗi
        </MudAlert>
        <MudSimpleTable Dense="true" Hover="true" Class="rounded-lg border-solid border mb-3" Style="border-width: 1px;">
            <thead><tr><th>TT</th><th>Họ tên</th><th>Quốc tịch</th><th>Hộ chiếu</th><th>Nghề nghiệp</th><th>GPLĐ</th></tr></thead>
            <tbody>
                <tr><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Mới</MudChip></td><td>Zhang Wei</td><td>Trung Quốc</td><td>E12345678</td><td>Kỹ sư</td><td>Có GPLĐ</td></tr>
                <tr><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Mới</MudChip></td><td>Kim Soo-hyun</td><td>Hàn Quốc</td><td>M98765432</td><td>Quản lý</td><td>Có GPLĐ</td></tr>
                <tr style="background: var(--mud-palette-warning-hover);"><td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Trùng</MudChip></td><td>Tanaka Yuki</td><td>Nhật Bản</td><td>TK4567890</td><td>Phiên dịch</td><td>Miễn</td></tr>
                <tr style="background: var(--mud-palette-error-hover);"><td><MudChip T="string" Size="Size.Small" Color="Color.Error">Lỗi</MudChip></td><td>Wang ???</td><td>Trung Quốc</td><td>—</td><td>—</td><td>—</td></tr>
            </tbody>
        </MudSimpleTable>

        <MudPaper Elevation="0" Class="pa-3 mb-3 rounded-lg" Style="background: var(--mud-palette-background);">
            <MudText Typo="Typo.subtitle2" Style="font-weight: 700;" Class="mb-2">Xử lý bản ghi trùng lặp:</MudText>
            <MudRadioGroup T="string" Value="@("update")">
                <MudRadio Value="@("update")" Color="Color.Primary" Dense="true">🔄 Cập nhật mới, lưu backup dữ liệu cũ</MudRadio>
                <MudRadio Value="@("skip")" Color="Color.Default" Dense="true">⏭️ Bỏ qua, giữ nguyên dữ liệu cũ</MudRadio>
            </MudRadioGroup>
        </MudPaper>

        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            🔒 <strong>Dữ liệu cũ sẽ được backup.</strong> Bạn có thể hoàn tác import bất cứ lúc nào từ lịch sử.
        </MudAlert>

        <MudStack Row="true" Justify="Justify.Center" Spacing="3">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => _currentStep = 2)" StartIcon="@Icons.Material.Filled.ArrowBack">Quay lại</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="@(() => _currentStep = 4)" StartIcon="@Icons.Material.Filled.FlashOn">Bắt đầu Import</MudButton>
        </MudStack>
    }

    @* Step 4: Result *@
    @if (_currentStep == 4)
    {
        <MudPaper Elevation="0" Class="pa-8 rounded-xl border-solid border text-center" Style="border-width: 1px;">
            <MudText Style="font-size: 3rem;">✅</MudText>
            <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 800;" Class="mt-2">Import hoàn tất!</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Phiên <strong>#IMP-2026-016</strong> · File <strong>DanhSachNLD_Samsung_2026.xlsx</strong>
            </MudText>

            <MudStack Row="true" Justify="Justify.Center" Spacing="8" Class="mt-6 mb-6">
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 800;">38</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Thêm mới</MudText>
                </MudStack>
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 800;">5</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Cập nhật</MudText>
                </MudStack>
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 800;">2</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Lỗi (bỏ qua)</MudText>
                </MudStack>
            </MudStack>

            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4 text-left">
                💾 <strong>Dữ liệu cũ đã được backup.</strong> 5 bản ghi cập nhật có thể hoàn tác bất cứ lúc nào.
            </MudAlert>

            <MudStack Row="true" Justify="Justify.Center" Spacing="3">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Undo"
                           OnClick="@(() => RollbackSession("IMP-2026-016"))">↩ Hoàn tác Import này</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default">📋 Xem chi tiết</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/employees">👥 Xem danh sách NLĐ</MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@inject ISnackbar Snackbar

@code {
    private int _currentStep = 1;
    private bool _showHistory = true;

    private void RollbackSession(string sessionId)
    {
        var session = _importHistory.FirstOrDefault(s => s.Id == sessionId);
        if (session != null)
        {
            var index = _importHistory.IndexOf(session);
            _importHistory[index] = session with { Status = "rolledback" };
            Snackbar.Add($"✅ Đã hoàn tác phiên {sessionId} — Dữ liệu đã khôi phục về trạng thái trước import.", Severity.Success);
        }
    }

    private record ImportSession(string Id, string Time, string FileName, string Company, int Added, int Updated, int Errors, string Status, string User);

    private List<ImportSession> _importHistory = new()
    {
        new("IMP-2026-016", "17/04/2026 09:30", "NLD_Samsung_2026.xlsx", "Samsung Electronics VN", 38, 5, 2, "committed", "Admin"),
        new("IMP-2026-015", "16/04/2026 14:15", "NLD_Canon_Q2.xlsx", "Canon Vietnam", 22, 3, 0, "committed", "Admin"),
        new("IMP-2026-014", "15/04/2026 10:00", "NLD_Hyundai_Update.xlsx", "Hyundai Aluminum Vina", 15, 8, 1, "rolledback", "Nguyễn Văn A"),
        new("IMP-2026-013", "10/04/2026 16:45", "NLD_LGDisplay.xlsx", "LG Display Vietnam", 31, 2, 0, "committed", "Trần Thị B"),
        new("IMP-2026-012", "05/04/2026 09:00", "NLD_Foxconn_T4.xlsx", "Foxconn Bình Dương", 45, 12, 3, "committed", "Admin"),
    };
}
