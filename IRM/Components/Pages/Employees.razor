@page "/employees"
@rendermode InteractiveServer

<PageTitle>Quản lý Nhân viên — IRM v2.0</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight: 800;">👥 Danh sách Nhân viên nước ngoài</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">Tổng: @_employees.Count nhân viên đang làm việc</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download"
                   Color="Color.Default">Xuất Excel</MudButton>
        <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PersonAdd"
                   Color="Color.Primary">Thêm nhân viên</MudButton>
    </MudStack>
</MudStack>

<MudDataGrid Items="@_employees" T="Employee" Filterable="true" Sortable="true"
             Dense="true" Hover="true" Striped="true"
             RowsPerPage="10" Class="rounded-lg border-solid border" Style="border-width: 1px;">
    <Columns>
        <PropertyColumn Property="x => x.Id" Title="STT" Sortable="false" Filterable="false" />
        <PropertyColumn Property="x => x.Name" Title="Họ tên" Style="font-weight: 600;" />
        <PropertyColumn Property="x => x.Nationality" Title="Quốc tịch" />
        <TemplateColumn Title="Hộ chiếu">
            <CellTemplate>
                <MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 12px; background: var(--mud-palette-background); padding: 2px 8px; border-radius: 4px;">@context.Item.Passport</MudText>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.Company" Title="Công ty" />
        <PropertyColumn Property="x => x.Career" Title="Nghề nghiệp" />
        <TemplateColumn Title="GPLĐ" Filterable="true" SortBy="@(x => x.PermitType)">
            <CellTemplate>
                @{
                    var color = context.Item.PermitType switch
                    {
                        "Có GPLĐ" => Color.Success,
                        "Miễn" => Color.Info,
                        _ => Color.Warning
                    };
                }
                <MudChip T="string" Size="Size.Small" Color="@color" Variant="Variant.Outlined">@context.Item.PermitType</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.StayExpiry" Title="Hạn tạm trú" />
        <TemplateColumn Title="Trạng thái" SortBy="@(x => x.DaysLeft)">
            <CellTemplate>
                @{
                    var (label, chipColor) = context.Item.DaysLeft switch
                    {
                        <= 7 => ("Sắp hết hạn", Color.Error),
                        <= 30 => ("Gần hết hạn", Color.Warning),
                        _ => ("Bình thường", Color.Success)
                    };
                }
                <MudChip T="string" Size="Size.Small" Color="@chipColor" Variant="Variant.Filled">@label</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Thao tác" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="Employee" />
    </PagerContent>
</MudDataGrid>

