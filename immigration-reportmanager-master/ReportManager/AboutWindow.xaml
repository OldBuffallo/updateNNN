<Window x:Class="ReportManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReportManager"
        ResizeMode="NoResize"
        mc:Ignorable="d"
        Title="About"  Height="179.695" Width="330.339">
    <Grid>
        <StackPanel Orientation="Vertical" Background="#a6d9ef" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" >
            <Border CornerRadius="25" Margin="20,10,20,10" BorderBrush="Red" Background="White">
                <StackPanel Orientation="Vertical">
                    <Label Content="Quản lý báo cáo" FontSize="20" HorizontalAlignment="Center" FontWeight="Bold" Margin="2,5,2,0" VerticalContentAlignment="Bottom"/>

                    <Grid Margin="2" >
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Margin="0,5" Padding="10,0,0,0" Content="Phiên bản : 2.4" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                        <Label Grid.Row="1" Grid.Column="0" Margin="0,5" Padding="10,0,0,0" Content="Nền tảng : win32(x64)" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                        <Label Grid.Row="2" Grid.Column="0" Margin="0,5" Padding="10,0,0,0" Content="Phát triển bởi IF Vietnam" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
