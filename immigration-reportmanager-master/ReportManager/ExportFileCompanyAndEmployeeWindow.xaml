<Window x:Class="ReportManager.ExportFileCompanyAndEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReportManager"
        mc:Ignorable="d"
        KeyDown="Window_KeyDown"
        ResizeMode="CanMinimize"
        SizeToContent="Height"
        Title="Xuất file" Height="620" Width="620">
    <StackPanel Background="#a6d9ef" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border CornerRadius="25" Margin="20" BorderBrush="Red" Background="White">
            <StackPanel Margin="0,10">
                <Label Content="Tùy chọn định dạng xuất file" Grid.Row="0" FontSize="25" HorizontalAlignment="Center" FontWeight="Bold" VerticalContentAlignment="Bottom"/>

                <!-- directory -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Đường dẫn: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="0,10, 20,5" Padding="0,4" Text="{Binding LinkFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" IsEnabled="False" FontSize="20"/>
                    <Button Grid.Column="2" Content="Lưu tại" Style="{DynamicResource BtnChoose}" Margin="0,10,20,5" Width="100" Command="{Binding BtnSaveLinkCommand}" Background="#f0ff00" Foreground="Black" BorderBrush="White"/>
                </Grid>

                <!--type-->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Xuất file: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Column="1" Margin="0,5,20,5" FontSize="20" Padding="5,4" SelectedIndex="{Binding SelectFormatFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Left">
                        <ComboBoxItem Name="cbbField" Content="Theo lĩnh vực"/>
                        <ComboBoxItem Content="Theo NNN và thời hạn tạm trú"/>
                    </ComboBox>

                </Grid>

                <!--type of export field-->
                <Grid Grid.Row="3" Name="gridcbbField" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Lĩnh vực: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Column="1" Margin="0,5,20,5" FontSize="20" Padding="5,4" ItemsSource="{Binding ListFields, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="FieldName" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>

                </Grid>

                <!--date export file-->
                <Grid Grid.Row="3" Name="DateExportFile">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Ngày xuất: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="0,10,20,10" FontSize="20" Padding="5,4" Text="{Binding DateExportFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TextBox_PreviewTextInput"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left" MouseDoubleClick="TextBox_MouseDoubleClick"/>
                </Grid>

                <!--temporary stay-->
                <Grid Grid.Row="4" Name="TemporaryStay">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Thời hạn TT: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="0,10,20,10" FontSize="20" Padding="5,4" Text="{Binding TemporaryStay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TextBox_PreviewTextInput"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left" MouseDoubleClick="TextBox_MouseDoubleClick"/>
                </Grid>

                <!--nationality-->
                <Grid Name="gridnationality" Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Quốc tịch: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="0,5,20,5" CharacterCasing="Upper" FontSize="20" Text="{Binding SelectNationality.NationalityCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left" LostFocus="TextBox_LostFocus"/>
                    <TextBox Grid.Column="2" IsReadOnly="True" Margin="0,5,20,5" FontSize="20" Text="{Binding SelectNationality.NationalityName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>

                <!-- button-->
                <StackPanel Orientation="Horizontal" Grid.Row="9" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Button Content="Xuất file" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnExportFileCommand}" Margin="20,0,20,0" Width="120" Height="35" FontSize="20" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                    <Button Content="Hủy bỏ" Style="{DynamicResource BtnCancel}" Command="{Binding BtnCancelCommand}" Margin="20,0,20,0" Width="120" Height="35" FontSize="20" Background="#ff2d2d" Foreground="Black" BorderBrush="White"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
