<UserControl x:Class="ReportManager.UserControls.ListCompaniesUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:base="clr-namespace:ReportManager.Bases"
             mc:Ignorable="d" MinWidth="1065" MinHeight="640"
             d:DesignHeight="640" d:DesignWidth="1065">
    <UserControl.Resources>
        <base:NumberOrderConvert x:Key="NumCOnverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="10,10,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Label Content="Danh sách công ty" Grid.Row="0" FontSize="25" HorizontalAlignment="Center" FontWeight="Bold" VerticalContentAlignment="Bottom"/>
            <StackPanel Grid.Row="1" Orientation="Vertical">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Xin chào " FontSize="20" Margin="0,20,0,0" Background="White" Foreground="Black"/>
                    <TextBlock Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="20" Margin="0,20,0,0" Background="White" Foreground="Black"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Làm mới" Style="{DynamicResource BtnChoose}" Width="120" Command="{Binding BtnRefreshCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="10,0,0,0" Padding="10,0" Background="#e6e600" Foreground="Black" BorderBrush="White"/>
                    <Button Content="Tìm kiếm" Style="{DynamicResource BtnSearch}" Width="120" Command="{Binding BtnSearchCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="20,0,0,0" Padding="10,0" Background="#3399ff" Foreground="Black" BorderBrush="White"/>
                    <Button Content="Thêm mới" Style="{DynamicResource BtnSuccess}" Width="120" Command="{Binding BtnAddCompanyCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="20,0,0,0" Padding="10,0" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                    <Button Content="Thông tin công ty" Style="{DynamicResource BtnSuccess}" Width="190" Command="{Binding BtnEditCompanyCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="20,0,0,0" Padding="10,0" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                    <Button Content="Lấy danh sách mail" Style="{DynamicResource BtnChoose}" Width="190" Command="{Binding BtnShowEmailCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="20,0,0,0"  Background="#e6e600" Foreground="Black" BorderBrush="White"/>
                    <Button Content="NNN sắp hết hạn" Style="{DynamicResource BtnChoose}" Width="190" Command="{Binding BtnAlmostExpiredCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="20,0,0,0"  Background="#e6e600" Foreground="Black" BorderBrush="White"/>
                </StackPanel>
                <!-- statistical -->
                <StackPanel Orientation="Horizontal">
                    <Label Content="Tổng:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumCompanies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="125" FontSize="18" HorizontalAlignment="Left"/>
                    <Label Content="Công ty ĐK:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumRegistrationCompanies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="80" FontSize="18" HorizontalAlignment="Left"/>
                    <Label Content="Công ty Chưa ĐK:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumUnregistrationCompanies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="80" FontSize="18" HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Tổng NNN:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumTotalAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="80" FontSize="18" HorizontalAlignment="Left"/>
                    <Label Content="Miễn GPLĐ:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumAmountOfExemption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="82" FontSize="18" HorizontalAlignment="Left"/>
                    <Label Content="Có GPLĐ:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumQuantityAvailable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="80" FontSize="18" HorizontalAlignment="Left"/>
                    <Label Content="Chưa GPLĐ:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumQuantityNotYet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="80" FontSize="18" HorizontalAlignment="Left"/>
                    <Label Content="Thân nhân sống cùng:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                    <Label Content="{Binding SumNumberOfPersonalities, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Width="80" FontSize="18" HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" Margin="10,10,10,20"
                      Name="dtgDataCompaniesInfo"
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Auto"
                      CanUserAddRows="False"
                      AutoGenerateColumns="False"
                      MouseDoubleClick="dtgDataCompaniesInfo_MouseDoubleClick"
                      SelectionChanged="dtgDataCompaniesInfo_SelectionChanged"
                  SelectedItem="{Binding SelectCompany, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding ListCompanies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <DataGrid.Columns>
                <DataGridTemplateColumn MinWidth="20" Width="45">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="STT" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LineNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="100" Width="3*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Tên pháp nhân" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Quốc tịch pháp nhân" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TypeOfBusiniess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="2*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Địa chỉ" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Lĩnh vực" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Field.FieldName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Mô tả hoạt động" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DescriptionOfActivities, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Đại diện pháp luật" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LegalRepresentative, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Tổng số NNN" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TotalAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Miễn GPLĐ" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding AmountOfExemption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Có GPLĐ" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding QuantityAvailable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Chưa Có GPLĐ" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding QuantityNotYet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Thân nhân sống cùng" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NumberOfPersonalities, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Hồ sơ đăng ký" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RegistrationProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Ghi chú" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Cán bộ theo dõi" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Tracker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
