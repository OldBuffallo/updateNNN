<UserControl x:Class="ReportManager.UserControls.AddCompanyUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:base="clr-namespace:ReportManager.Bases"
             mc:Ignorable="d" MinWidth="1065" MinHeight="640"
             d:DesignHeight="640" d:DesignWidth="1065">
    <UserControl.Resources>
        <base:MoneyConvert x:Key="MoneyConvert"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- label add company-->
        <Label Name="LabelAddCompany" Visibility="Hidden" Grid.Row="0" Content="Thêm Công Ty" FontSize="30" HorizontalContentAlignment="Center" FontWeight="Medium" Margin="2,0,2,10" FontStyle="Italic" VerticalContentAlignment="Center"/>
        <!-- label edit company-->
        <Label Name="LabelEditCompany" Grid.Row="0" Content="Thông Tin Công Ty" FontSize="30" HorizontalContentAlignment="Center" FontWeight="Medium" Margin="2,0,2,10" FontStyle="Italic" VerticalContentAlignment="Center"/>
        <!--content-->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="5*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <!--company name -->
                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Tên pháp nhân * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,20,5" Text="{Binding AddComapany.CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--type of businiess -->
                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Quốc tịch pháp nhân * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,20,5" Text="{Binding AddComapany.TypeOfBusiniess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--uptime -->
                <Grid Grid.Row="2" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Thời gian hoạt động * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox x:Name="uptime" Grid.Column="1" Margin="20,5,20,5" Text="{Binding AddComapany.Uptime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="uptime_PreviewTextInput"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--legal respresentative -->
                <Grid Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Đại điện pháp luật * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,20,5" Text="{Binding AddComapany.LegalRepresentative, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--address -->
                <Grid Grid.Row="3" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Địa chỉ * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,20,5" Text="{Binding AddComapany.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--district -->
                <Grid Grid.Row="3" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Phường/Xã  * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Column="1" Margin="20,5,20,5" DataObject.Pasting="ComboBox_Pasting" IsEditable="True" IsTextSearchEnabled="False" PreviewKeyUp="ComboBox_PreviewKeyUp" PreviewTextInput="ComboBox_PreviewTextInput" ItemsSource="{Binding Ward, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectWard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--field -->
                <Grid Grid.Row="4" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Lĩnh vực * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Column="1" Margin="20,5,20,5" ItemsSource="{Binding ListFields, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="FieldName" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--registration profile -->
                <Grid Grid.Row="4" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Hồ sơ đăng ký * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Name="cbbRegistrationProfileIndex" Margin="20,5,5,5" SelectedIndex="{Binding AddComapany.RegistrationProfileIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" SelectionChanged="cbbRegistrationProfileIndex_SelectionChanged">
                            <ComboBoxItem Content="Không"/>
                            <ComboBoxItem Content="Có"/>
                        </ComboBox>
                        <TextBox Grid.Column="1" Name="txtRegistrationProfile" Margin="5,5,20,5" Text="{Binding AddComapany.RegistrationProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                    </Grid>
                </Grid>
                <!--description of activities -->
                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Mô tả hoạt động   : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,20,5" Text="{Binding AddComapany.DescriptionOfActivities, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!-- tracker-->
                <Grid Grid.Row="6" Grid.Column="0" Name="gridTracker" Visibility="Hidden">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Cán bộ theo dõi * : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Column="1" Margin="20,5,20,5" ItemsSource="{Binding ListTracker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectTracker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--note -->
                <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Ghi chú   : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,20,5" Text="{Binding AddComapany.Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
            </Grid>
            <!-- investment -->
            <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="7*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Content="Bảng vốn đầu tư" FontSize="20" HorizontalContentAlignment="Center" FontWeight="Medium" Margin="2,0,2,5" FontStyle="Italic" VerticalContentAlignment="Center"/>
                <!--owner -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Chủ sở hữu: " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,0,5" Text="{Binding InputInvestment.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--nationality -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Quốc tịch: " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Column="1" Margin="20,5,0,5" ItemsSource="{Binding Listnationalities, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="NationalityName" SelectedItem="{Binding InputNationality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--passport-->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Số hộ chiếu: " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,0,5" Text="{Binding InputInvestment.Passport, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!--money -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Số tiền: " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="20,5,0,5" Text="{Binding InputInvestment.AmountOfMoney, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="number_PreviewTextInput" TextChanged="TextBox_TextChanged"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                </Grid>
                <!-- button attach-->
                <Button Grid.Row="5" Content="Đính kèm" Name="btnAttach" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnAttachCommand}" Margin="0,5,30,5" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White" HorizontalAlignment="Left"/>
                <!-- button add investment -->
                <Button Grid.Row="5" Content="Thêm vốn" Style="{DynamicResource BtnSuccess}" Command="{Binding AddInvestmentCommand}" Margin="0,5,30,5" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White" HorizontalAlignment="Right"/>
                <!--table investment-->
                <DataGrid Grid.Row="7" Margin="10,10,0,0"
                      Name="dtgDataInvestmentInfo"
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Auto"
                      CanUserAddRows="False"
                      AutoGenerateColumns="False"
                      MouseDoubleClick="dtgDataInvestmentInfo_MouseDoubleClick"
                      SelectedItem="{Binding SelectInvestment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding ListInvestment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="5*">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Chủ sở hữu" TextAlignment="Center" TextWrapping="Wrap" Padding="10,0,0,0" FontSize="18"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="18" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="3*">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Quốc tịch" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Nationality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="18" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="3*">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Số hộ chiếu" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Passport, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="18" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="5*">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Số tiền" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AmountOfMoney, Converter={StaticResource MoneyConvert}}" TextWrapping="Wrap" FontSize="18" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            <!-- email & phone number-->
            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <!-- email -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="4*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Danh sách Email" FontSize="20" HorizontalContentAlignment="Center" FontWeight="Medium" Padding="10,0" Margin="2,0,2,5" FontStyle="Italic" VerticalContentAlignment="Center"/>
                    <!-- button add email -->
                    <Button Grid.Row="1" Content="Thêm email" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnAddEmailCommand}" Margin="0,5,50,5" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White" HorizontalAlignment="Right"/>
                    <!-- table email-->
                    <DataGrid Grid.Row="2" Margin="20,10,10,0"
                      Name="dtgDataEmailsInfo"
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Auto"
                      CanUserAddRows="False"
                      AutoGenerateColumns="False"
                      MouseDoubleClick="dtgDataEmailsInfo_MouseDoubleClick"
                      SelectedItem="{Binding SelectEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding ListEmails, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="5*">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="Tên" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="18" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="8*">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="Email" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Mail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="18" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                <!-- phone number -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="4*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Danh sách số điện thoại" FontSize="20" HorizontalContentAlignment="Center" FontWeight="Medium" Padding="10,0" Margin="2,0,2,5" FontStyle="Italic" VerticalContentAlignment="Center"/>
                    <!-- button add email -->
                    <Button Grid.Row="1" Content="Thêm SĐT" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnAddPhoneNumberCommand}" Margin="0,5,50,5" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White" HorizontalAlignment="Right"/>
                    <!-- table email-->
                    <DataGrid Grid.Row="2" Margin="10,10,10,0"
                      Name="dtgDataPhoneNumbersInfo"
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Auto"
                      CanUserAddRows="False"
                      AutoGenerateColumns="False"
                      MouseDoubleClick="dtgDataPhoneNumbersInfo_MouseDoubleClick"
                      SelectedItem="{Binding SelectPhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding ListPhoneNumbers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="5*">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="Tên" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="18" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="8*">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="Số điện thoại" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" FontSize="18" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
        <!--button-->
        <StackPanel Name="AddCompany" Visibility="Hidden" Orientation="Horizontal" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center">
            <Button Content="Thêm" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnAddCompanyCommand}" Margin="20,0,20,30" Width="120" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
            <Button Content="Hủy bỏ" Style="{DynamicResource BtnCancel}" Command="{Binding BtnExitCommand}" Margin="20,0,20,30" Width="120" Height="30" Background="#ff2d2d" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
        </StackPanel>
        <StackPanel Name="EditCompany" Orientation="Horizontal" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center">
            <Button Content="Lưu lại" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnUpdateCompanyCommand}" Margin="20,0,20,30" Width="120" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
            <Button Content="Xóa" Style="{DynamicResource BtnChoose}" Command="{Binding BtnDeleteCompanyCommand}" Margin="20,0,20,30" Width="120" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
            <Button Content="Hủy bỏ" Style="{DynamicResource BtnCancel}" Command="{Binding BtnExitCommand}" Margin="20,0,20,30" Width="120" Height="30" Background="#ff2d2d" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</UserControl>
