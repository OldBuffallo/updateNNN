<UserControl x:Class="ReportManager.UserControls.AddEmployeeUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReportManager.UserControls"
             mc:Ignorable="d" MinWidth="1065" MinHeight="640"
             d:DesignHeight="640" d:DesignWidth="1065">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.7*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1.3*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Thông tin nhân viên" FontSize="30" HorizontalContentAlignment="Center" FontWeight="Medium" Margin="2,0,2,10" FontStyle="Italic" VerticalContentAlignment="Center"/>
        <!-- staff name-->
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Họ và tên * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.StaffName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--gender-->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Giới tính   : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <ComboBox Grid.Column="1" Margin="20,10" FontSize="18" Width="100" SelectedIndex="{Binding SelectGender, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Left">
                <ComboBoxItem Content="Nam"/>
                <ComboBoxItem Content="Nữ"/>
            </ComboBox>
        </Grid>
        <!--birthday-->
        <Grid Grid.Row="2" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Ngày sinh * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" FontSize="18" Margin="20,10" Text="{Binding NewEmployee.Birthday, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="Date_PreviewTextInput"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left" MouseDoubleClick="TextBox_MouseDoubleClick"/>
        </Grid>
        <!--passport-->
        <Grid Grid.Row="3" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Số hộ chiếu * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" FontSize="18" Margin="20,10" Text="{Binding NewEmployee.Passport, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TextNum_PreviewTextInput"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--nationality-->
        <Grid Grid.Row="3" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Quốc tịch   : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" Margin="20,10" CharacterCasing="Upper" FontSize="18" Text="{Binding NewEmployee.Nationality.NationalityCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left" LostFocus="TextBox_LostFocus"/>
            <TextBox Grid.Column="2" IsReadOnly="True" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.Nationality.NationalityName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--temporary address-->
        <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Địa chỉ tạm trú * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
            <!-- Address Ward-->
            <Label Grid.Column="2" Margin="0,5" Content="Phường (Xã) * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <ComboBox Grid.Column="3" Margin="20,10" DataObject.Pasting="ComboBox_Pasting" IsEditable="True" IsTextSearchEnabled="False" PreviewKeyUp="ComboBox_PreviewKeyUp" PreviewTextInput="ComboBox_PreviewTextInput" ItemsSource="{Binding ListWards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectWard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--career group-->
        <Grid Grid.Row="5" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Nhóm nghề nghiệp   : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <ComboBox Grid.Column="1" Margin="20,10" ItemsSource="{Binding ListCareerGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectCareerGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="CareerGroupName" FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--career-->
        <Grid Grid.Row="5" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Nghề nghiệp   : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <ComboBox Grid.Column="1" Margin="20,10" ItemsSource="{Binding ListCareers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectCareer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="CareerName" FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--work permit-->
        <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Số GPLĐ/ thời hạn * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <ComboBox Name="workPermitcmb" Grid.Column="1" Margin="20,10" FontSize="18" Width="250" SelectedIndex="{Binding NewEmployee.WorkPermit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="ComboBox_SelectionChanged" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                <ComboBoxItem Content="NLĐ miễn giấy phép GPLĐ"/>
                <ComboBoxItem Content="NLĐ đã có GPLĐ"/>
                <ComboBoxItem Content="NLĐ chưa có GPLĐ"/>
                <ComboBoxItem Content="Nhà đầu tư miễn GPLĐ"/>
                <ComboBoxItem Content="Nhà đầu tư đã có GPLĐ"/>
                <ComboBoxItem Content="Nhà đầu tư chưa có GPLĐ"/>
                <ComboBoxItem Content="Khác"/>
            </ComboBox>
            <TextBox Name="workPermitText" Grid.Column="2" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.WorkPermitNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--visa number-->
        <Grid Grid.Row="7" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Số visa/ Thẻ tạm trú * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.VisaNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TextNum_PreviewTextInput"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!-- temporary stay-->
        <Grid Grid.Row="7" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Thời hạn tạm trú * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.TemporaryStay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="Date_PreviewTextInput"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left" MouseDoubleClick="TextBox_MouseDoubleClick"/>
        </Grid>
        <!-- settlement results-->
        <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Kết quả giải quyết   : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <ComboBox Grid.Column="1" Margin="20,10,10,10" FontSize="18" Width="150" SelectedIndex="{Binding NewEmployee.SettlementResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                <ComboBoxItem Content="GHTT"/>
                <ComboBoxItem Content="Visa"/>
                <ComboBoxItem Content="TTT"/>
                <ComboBoxItem Content="Khác"/>
            </ComboBox>
            <TextBox Grid.Column="2" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.SettlementResultsString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!-- working status-->
        <Grid Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Trạng thái   : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <ComboBox Name="cbbWorkingStatus" SelectedIndex="{Binding NewEmployee.WorkingStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="20,10,10,10" FontSize="18" Width="150" SelectionChanged="cbbWorkingStatus_SelectionChanged" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                <ComboBoxItem Content="Đang làm"/>
                <ComboBoxItem Content="Nghỉ việc"/>
            </ComboBox>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!-- date of join-->
                <Grid Name="gridDateOfJoin" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Bắt đầu làm từ : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Name="txtDateOfJoin" Grid.Column="1" Text="{Binding NewEmployee.DateOfJoin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Margin="20,10" PreviewTextInput="Date_PreviewTextInput"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left" MouseDoubleClick="TextBox_MouseDoubleClick"/>
                </Grid>
                <!-- date of leave-->
                <Grid Name="gridDateOfLeave" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Ngày nghỉ * : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Name="txtDateOfLeave" Grid.Column="1" Text="{Binding NewEmployee.DateOfLeave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Margin="20,10" PreviewTextInput="Date_PreviewTextInput"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left" MouseDoubleClick="TextBox_MouseDoubleClick"/>
                </Grid>
            </Grid>
        </Grid>
        <!--note-->
        <Grid Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Margin="0,5" Content="Ghi chú   : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
            <TextBox Grid.Column="1" Margin="20,10" FontSize="18" Text="{Binding NewEmployee.Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
        </Grid>
        <!--button-->
        <StackPanel Name="addEmployee" Visibility="Hidden" Orientation="Horizontal" Grid.Row="11" Grid.ColumnSpan="2" HorizontalAlignment="Center">
            <Button Content="Thêm" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnAddEmployeeCommand}" Margin="20,0,20,30" Width="120" Height="30" FontSize="20" Background="#80ff00" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
            <Button Content="Hủy bỏ" Style="{DynamicResource BtnCancel}" Command="{Binding BtnCancelCommand}" Margin="20,0,20,30" Width="120" Height="30" FontSize="20" Background="#ff2d2d" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
        </StackPanel>
        <StackPanel Name="editEmployee" Orientation="Horizontal" Grid.Row="11" Grid.ColumnSpan="2" HorizontalAlignment="Center">
            <Button Name="btnUpdateAndCreate" Content="Cập nhật" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnAddEmployeeCommand}" Margin="20,0,20,30" Width="120" Height="30" FontSize="20" Background="#80ff00" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
            <Button Name="btnUpdate" Content="Sửa không lưu dữ liệu cũ" Style="{DynamicResource BtnSuccess}" Command="{Binding BtnEditEmployeeCommand}" Margin="20,0,20,30" Width="240" Height="30" FontSize="20" Background="#80ff00" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
            <Button Name="btnDelete" Content="Xóa" Style="{DynamicResource BtnChoose}" Command="{Binding BtnDeleteEmployeeCommand}" Margin="20,0,20,30" Width="120" Height="30" FontSize="20" Background="#80ff00" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
            <Button Content="Hủy bỏ" Style="{DynamicResource BtnCancel}" Command="{Binding BtnCancelCommand}" Margin="20,0,20,30" Width="120" Height="30" FontSize="20" Background="#ff2d2d" Foreground="Black" BorderBrush="White" VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</UserControl>
