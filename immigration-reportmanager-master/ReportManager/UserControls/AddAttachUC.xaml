<UserControl x:Class="ReportManager.UserControls.AddAttachUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReportManager.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <Grid Margin="13,15,27,30" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Vertical">
                <Grid Grid.Row="0" Margin="10,10,10,0">
                    <Label Content="Thêm file đính kèm" Grid.Row="0" FontSize="25" HorizontalAlignment="Center" FontWeight="Bold" VerticalContentAlignment="Bottom"/>
                </Grid>

                <!--path file-->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Đường dẫn: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="0,10, 20,10" Padding="0,4" Text="{Binding LinkFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" IsEnabled="False" FontSize="20"/>
                    <Button Grid.Column="2" Content="Chọn file" Style="{DynamicResource BtnChoose}" Margin="0,10,20,10" Width="100" Command="{Binding BtnChooseLinkCommand}" Background="#f0ff00" Foreground="Black" BorderBrush="White"/>
                </Grid>

                <!--name -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Tên file: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Column="1" Margin="0,10,0,10" FontSize="20" Padding="5,4" Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TextBox_PreviewTextInput"   VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                    <Label Grid.Column="2" Margin="0,5" Content="." FontSize="20" FontWeight="Bold" VerticalContentAlignment="Bottom" HorizontalContentAlignment="Center"/>
                    <TextBox Grid.Column="3" Margin="0,10, 20,10" Padding="0,4" Text="{Binding ExtensionFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" IsEnabled="False" FontSize="20"/>
                </Grid>

                <!--type-->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Margin="0,5" Content="Loại file: " FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Column="1" Margin="0,5,20,5" FontSize="20" Padding="5,4" SelectedIndex="{Binding AddAttach.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Left">
                        <ComboBoxItem Content="Báo cáo NNN"/>
                        <ComboBoxItem Content="Hồ sơ pháp nhân"/>
                    </ComboBox>
                </Grid>

                <!--button-->
                <StackPanel Name="spAdd" Visibility="Hidden" Orientation="Horizontal" Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="2" HorizontalAlignment="Center">
                    <Button x:Name="BtnSuccess" Style="{DynamicResource BtnSuccess}" Content="Thêm" FontSize="18" Command="{Binding BtnCreateAttachCommand}" Margin="5,10" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                    <Button x:Name="BtnCancel" Style="{DynamicResource BtnCancel}" Content="Hủy" FontSize="18" Command="{Binding BtnExitCommand}" Margin="5,10" Width="100" Height="30" Background="#ff2d2d" Foreground="Black" BorderBrush="White"/>
                </StackPanel>
                <StackPanel Name="spEdit" Orientation="Horizontal" Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="2" HorizontalAlignment="Center">
                    <Button Style="{DynamicResource BtnSuccess}" Content="Sửa" FontSize="18" Command="{Binding BtnEditAttachCommand}" Margin="5,10" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                    <Button Style="{DynamicResource BtnChoose}" Content="Xóa" FontSize="18" Command="{Binding BtnDeleteAttachCommand}" Margin="5,10" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                    <Button Style="{DynamicResource BtnCancel}" Content="Hủy" FontSize="18" Command="{Binding BtnExitCommand}" Margin="5,10" Width="100" Height="30" Background="#ff2d2d" Foreground="Black" BorderBrush="White"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
