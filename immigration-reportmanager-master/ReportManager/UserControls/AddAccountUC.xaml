<UserControl x:Class="ReportManager.UserControls.AddAccountUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReportManager.UserControls"
             mc:Ignorable="d" MaxHeight="350"
             d:DesignHeight="350" d:DesignWidth="680">
    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Vertical">
                <Grid Margin="20, 20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Margin="0,5" Content="Tài khoản : " FontSize="18" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Row="0" Text="{Binding AccountLogin.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" PreviewTextInput="TextBox_PreviewTextInput" Grid.Column="1" Margin="25,5,0,5"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>

                    <Label Grid.Row="1" Grid.Column="0" Margin="0,5" Content="Mật khẩu : " VerticalContentAlignment="Center" FontSize="18" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Row="1"  Grid.Column="1" Text="{Binding AccountLogin.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" PreviewTextInput="TextBox_PreviewTextInput"  Margin="25,5,0,5" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>

                    <Label Grid.Row="2" Grid.Column="0" Margin="0,5" Content="Tên cán bộ : " VerticalContentAlignment="Center" FontSize="18" HorizontalContentAlignment="Right"/>
                    <TextBox Grid.Row="2"  Grid.Column="1" Text="{Binding AccountLogin.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" LostKeyboardFocus="TextBox_LostKeyboardFocus" Margin="25,5,0,5" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>

                    <Label Grid.Row="3" Grid.Column="0" Margin="0,5" Content="Quyền hạn : " VerticalContentAlignment="Center" FontSize="18" HorizontalContentAlignment="Right"/>
                    <ComboBox Grid.Row="3"  Grid.Column="1" SelectedIndex="{Binding AccountLogin.PermissionIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Margin="25,5,0,5" VerticalContentAlignment="Center" HorizontalContentAlignment="Left">
                        <ComboBoxItem Content="Người quản lý"></ComboBoxItem>
                        <ComboBoxItem Content="Người dùng"></ComboBoxItem>
                    </ComboBox>

                    <StackPanel Name="spAdd" Visibility="Hidden" Orientation="Horizontal" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" HorizontalAlignment="Center">
                        <Button x:Name="BtnSuccess" Style="{DynamicResource BtnSuccess}" Content="Thêm" Command="{Binding BtnCreateAccountCommand}" Margin="5,10" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                        <Button x:Name="BtnCancel" Style="{DynamicResource BtnCancel}" Content="Hủy" Command="{Binding BtnExitCommand}" Margin="5,10" Width="100" Height="30" Background="#ff2d2d" Foreground="Black" BorderBrush="White"/>
                    </StackPanel>
                    <StackPanel Name="spEdit" Orientation="Horizontal" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Style="{DynamicResource BtnSuccess}" Content="Sửa" Command="{Binding BtnCreateAccountCommand}" Margin="5,10" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                        <Button Style="{DynamicResource BtnChoose}" Content="Xóa" Command="{Binding BtnDeleteAccountCommand}" Margin="5,10" Width="100" Height="30" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
                        <Button Style="{DynamicResource BtnCancel}" Content="Hủy" Command="{Binding BtnExitCommand}" Margin="5,10" Width="100" Height="30" Background="#ff2d2d" Foreground="Black" BorderBrush="White"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
