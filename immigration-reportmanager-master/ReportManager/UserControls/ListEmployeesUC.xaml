<UserControl x:Class="ReportManager.UserControls.ListEmployeesUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReportManager.UserControls"
             mc:Ignorable="d" MinWidth="1065" MinHeight="640"
             d:DesignHeight="640" d:DesignWidth="1065">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>
        <Label Content="{Binding Company.CompanyName}" Grid.Row="0" FontSize="25" HorizontalAlignment="Left" FontWeight="Bold" VerticalContentAlignment="Bottom"/>
        <!-- address company-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Địa chỉ:" Grid.Column="0" FontSize="18" HorizontalAlignment="Left"/>
            <Label Content="{Binding Company.Address}" Grid.Column="1" FontSize="18" HorizontalAlignment="Left"/>
        </Grid>
        <!-- phone number company-->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="SĐT:" Grid.Column="0" FontSize="18" HorizontalAlignment="Left"/>
            <Label Content="{Binding Company.PhoneNumber}" Grid.Column="1" FontSize="18" HorizontalAlignment="Left"/>
        </Grid>
        <Label Content="Danh sách người nước ngoài hiện đang làm việc tại công ty" Grid.Row="3" FontSize="25" HorizontalAlignment="Center" FontWeight="Bold" VerticalContentAlignment="Bottom"/>
        <!--button and sum -->
        <StackPanel Grid.Row="5" Orientation="Horizontal">
            <Button Content="Làm mới" Style="{DynamicResource BtnChoose}" Width="130" Command="{Binding LoadDataEmployeesCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="10,0,0,0" Padding="10,0" Background="#e6e600" Foreground="Black" BorderBrush="White"/>
            <Button Content="Tìm kiếm" Style="{DynamicResource BtnSearch}" Width="130" Command="{Binding BtnSearchCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="10,0,0,0" Padding="10,0" Background="#3399ff" Foreground="Black" BorderBrush="White"/>
            <Button Content="Thêm" Style="{DynamicResource BtnSuccess}" Width="130" Command="{Binding BtnAddEmployeeCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="10,0,0,0" Padding="10,0" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
            <Button Content="Đọc từ file" Style="{DynamicResource BtnSuccess}" Width="130" Command="{Binding BtnReadFileCommand}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Margin="10,0,0,0" Padding="10,0" Background="#80ff00" Foreground="Black" BorderBrush="White"/>
        </StackPanel>
        <StackPanel Grid.Row="6" Orientation="Horizontal">
            <Grid Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Label Content="Tổng:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                <Label Content="{Binding Sum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" FontSize="18" HorizontalAlignment="Left"/>
            </Grid>
            <Grid Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Label Content="GHTT:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                <Label Content="{Binding SumGHTT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" FontSize="18" HorizontalAlignment="Left"/>
            </Grid>
            <Grid Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Label Content="Visa:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                <Label Content="{Binding SumVisa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" FontSize="18" HorizontalAlignment="Left"/>
            </Grid>
            <Grid Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Label Content="TTT:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                <Label Content="{Binding SumTemporaryResidenceCard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" FontSize="18" HorizontalAlignment="Left"/>
            </Grid>
            <Grid Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Label Content="Khác:" Grid.Column="0" FontSize="18" HorizontalAlignment="Right"/>
                <Label Content="{Binding SumOther, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" FontSize="18" HorizontalAlignment="Left"/>
            </Grid>
        </StackPanel>
        <!-- list data-->
        <DataGrid Grid.Row="7" Margin="10,10,10,10"
                Name="dtgDataEmployeesInfo"
                VerticalScrollBarVisibility="Auto" 
                HorizontalScrollBarVisibility="Auto"
                CanUserAddRows="False"
                AutoGenerateColumns="False"
                MouseDoubleClick="dtgDataEmployeesInfo_MouseDoubleClick"
                SelectionChanged="dtgDataEmployeesInfo_SelectionChanged"
                SelectedItem="{Binding SelectEmployee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ItemsSource="{Binding ListEmployees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <DataGrid.Columns>
                <DataGridTemplateColumn MinWidth="20" Width="40">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="STT" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LineNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="1*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Họ và tên" TextAlignment="Center" TextWrapping="Wrap" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StaffName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="50">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Giới tính" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GenderString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="110">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Ngày sinh" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Birthday, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Quốc tịch" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nationality.NationalityName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="110">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Số hộ chiếu" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Passport, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="100" Width="170">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Địa chỉ tạm trú" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="115">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Nghề nghiệp" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Career.CareerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="130">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Số GPLĐ/Thời hạn" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding WorkPermitDisplay}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="50" Width="100">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Số visa/Thẻ tạm trú" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding VisaNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="110">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Thời hạn tạm trú" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TemporaryStay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="60" Width="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Kết quả giải quyết" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SettlementResultsDisplay}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn MinWidth="40" Width="90">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Ghi chú" TextWrapping="Wrap" TextAlignment="Center" FontSize="18"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!--back button-->
        <Grid Grid.Row="8" Margin="0,0,0,30" VerticalAlignment="Bottom">
            <Button Content="Quay lại" Style="{DynamicResource BtnCancel}" Command="{Binding BtnBackCommand}" Width="120" Height="30" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Bottom" FontSize="20" Margin="10,0,0,0" Padding="10,0" Background="#e6e600" Foreground="Black" BorderBrush="White"/>
        </Grid>
    </Grid>
</UserControl>
