<Window x:Class="ReportManager.ShowImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReportManager"
        mc:Ignorable="d"
        Title="Show Image" Height="450" Width="800">
    <Grid Background="#a6d9ef" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border CornerRadius="25" Margin="20" BorderBrush="Red" Background="White">
            <StackPanel Margin="0,10">
                <!-- label edit company-->
                <Label Content="Xem Ảnh Công Ty" FontSize="20" HorizontalContentAlignment="Center" FontWeight="Medium" Margin="2,0,2,10" FontStyle="Italic" VerticalContentAlignment="Center"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="2" Name="BtnChange" Content="Thay đổi" Style="{DynamicResource BtnChoose}" Margin="0,10,20,10" Width="100" Height="30" Click="BtnChange_Click" Background="#f0ff00" Foreground="Black" BorderBrush="White"/>
                </Grid>
                <Image Name="ImageViewer1" Margin="10"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
