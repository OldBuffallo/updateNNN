<Window x:Class="ReportManager.DisplayEmailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReportManager"
        mc:Ignorable="d" Height="330" Width="680"
        ResizeMode="CanMinimize"
        Title="Danh sách Email" MinHeight="330" MinWidth="680">
    <Grid Background="#a6d9ef" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border CornerRadius="25" Margin="20" BorderBrush="Red" Background="White">
            <Grid Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <!-- content-->
                <TextBox Grid.Row="1" Text="{Binding ShowEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="10,5" TextWrapping="Wrap" FontSize="20" AcceptsReturn="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"/>
                <!-- button-->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Đóng" Style="{DynamicResource BtnCancel}" Command="{Binding BtnCloseCommand}" Margin="20,0,20,0" Width="120" Height="35" FontSize="20" Background="#ff2d2d" Foreground="Black" BorderBrush="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
