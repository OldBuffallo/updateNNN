<Window x:Class="ReportManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels ="clr-namespace:ReportManager.ViewModels"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Title="Đăng nhập" Height="303" Width="385">
    <Window.Resources>
        <viewModels:MainViewModel x:Key="MainViewModel"></viewModels:MainViewModel>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Width="Auto" Height="20" >
            <MenuItem Header="Cài đặt">
                <MenuItem Header="Kiểm tra kết nối" Command="{Binding BtnCheckConnectCommand}"/>
                <MenuItem Header="Cấu hình" Command="{Binding BtnSettingsCommand}" />
                <Separator />
                <MenuItem Header="Thoát" Command="{Binding BtnExitCommand}" />
            </MenuItem>
            <MenuItem Header="Trợ giúp">
                <MenuItem Header="Hướng dẫn" Command="{Binding BtnTutorialCommand}"/>
                <MenuItem Header="Về chúng tôi" Command="{Binding BtnAboutCommand}"/>
            </MenuItem>
        </Menu>
        <!--login-->
        <Grid Grid.Row="1">
            <StackPanel Orientation="Vertical" Background="#a6d9ef" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" >
                <Border CornerRadius="25" Margin="20,10,20,10" BorderBrush="Red" Background="White" Width="330">
                    <StackPanel Orientation="Vertical">
                        <Label Content="Welcome" FontSize="25" HorizontalAlignment="Center" FontWeight="Bold" Margin="2,5,2,0" VerticalContentAlignment="Bottom"/>
                        <Label Visibility="Hidden" Content="Please Login to Proceed" FontSize="20" HorizontalContentAlignment="Center" FontWeight="Medium" Margin="2,0,2,10" FontStyle="Italic" VerticalContentAlignment="Top"/>

                        <Grid Margin="2" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Margin="0,5" Content="Tài khoản : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                            <TextBox Grid.Row="0" Text="{Binding AccountLogin.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="TextBox_PreviewTextInput" Grid.Column="1" Margin="0,5" Width="150"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>

                            <Label Grid.Row="1" Grid.Column="0" Margin="0,5" Content="Mật khẩu : " VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                            <PasswordBox  Grid.Row="1"  Grid.Column="1" PasswordChar="*" PasswordChanged="PasswordBox_PasswordChanged" PreviewTextInput="TextBox_PreviewTextInput"  Margin="0,5" Width="150" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>

                            <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center">
                                <Button Content="Đăng nhập" Style="{DynamicResource BtnSuccess}" Margin="2,10" Width="100" Height="30" Command="{Binding BtnLoginCommand}"/>
                                <Button Content="Đóng" Style="{DynamicResource BtnCancel}" Margin="2,10" Width="100" Height="30" Command="{Binding BtnExitCommand}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
